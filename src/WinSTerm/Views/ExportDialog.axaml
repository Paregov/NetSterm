<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:views="clr-namespace:WinSTerm.Views"
        x:Class="WinSTerm.Views.ExportDialog"
        x:CompileBindings="False"
        Title="Export Configuration"
        Width="500" Height="550"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>
        <views:BoolToFolderIconConverter x:Key="FolderIconConverter"/>
    </Window.Resources>

    <Window.DataTemplates>
        <TreeDataTemplate DataType="{x:Type views:ExportTreeItem}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <CheckBox IsChecked="{Binding IsChecked}"
                          IsThreeState="True"
                          VerticalAlignment="Center"/>
                <mi:MaterialIcon Kind="{Binding IsFolder, Converter={StaticResource FolderIconConverter}}"
                                 Width="14" Height="14"
                                 VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Name}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </TreeDataTemplate>
    </Window.DataTemplates>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Select items to export:"
                   FontSize="14" FontWeight="SemiBold"
                   Margin="0,0,0,8"/>

        <!-- Tree view -->
        <Border Grid.Row="1"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="2">
            <TreeView ItemsSource="{Binding TreeItems}"
                      Padding="4">
                <TreeView.Styles>
                    <Style Selector="TreeViewItem">
                        <Setter Property="IsExpanded" Value="True"/>
                    </Style>
                </TreeView.Styles>
            </TreeView>
        </Border>

        <!-- Options section -->
        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock Text="Options"
                       FontSize="13" FontWeight="SemiBold"
                       Margin="0,0,0,6"/>

            <CheckBox Content="Include passwords"
                      IsChecked="{Binding IncludePasswords}"
                      Margin="0,2"/>
            <TextBlock Text="&#x26A0; Passwords will be stored in plaintext. Only use for personal backups."
                       FontSize="11"
                       Opacity="0.5"
                       Margin="20,0,0,4"
                       TextWrapping="Wrap"/>

            <CheckBox Content="Include private key files"
                      IsChecked="{Binding IncludePrivateKeys}"
                      Margin="0,2"/>
        </StackPanel>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Export"
                    Width="90" Height="32"
                    Click="OkButton_Click"
                    Classes="accent"
                    Margin="0,0,8,0"/>
            <Button Content="Cancel"
                    Width="90" Height="32"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
