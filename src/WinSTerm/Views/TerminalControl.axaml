<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv="using:AvaloniaWebView"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="WinSTerm.Views.TerminalControl"
             KeyDown="OnKeyDown">
    <Grid>
        <wv:WebView x:Name="TerminalWebView" />

        <!-- Search overlay bar -->
        <Border x:Name="SearchBar"
                IsVisible="False"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,4,16,0"
                Background="#252526"
                BorderBrush="#3e3e42"
                BorderThickness="1"
                CornerRadius="2"
                Padding="6,4">
            <StackPanel Orientation="Horizontal">
                <mi:MaterialIcon Kind="Magnify"
                                 Width="14" Height="14"
                                 VerticalAlignment="Center"
                                 Foreground="#999999"
                                 Margin="0,0,6,0" />
                <TextBox x:Name="SearchTextBox"
                         Width="200"
                         FontSize="13"
                         VerticalContentAlignment="Center"
                         Watermark="Find in terminal..."
                         Background="#3c3c3c"
                         Foreground="#cccccc"
                         BorderBrush="#3e3e42"
                         CaretBrush="#cccccc"
                         TextChanged="SearchTextBox_TextChanged"
                         KeyDown="SearchTextBox_KeyDown" />
                <Button x:Name="PreviousMatchButton"
                        Click="PreviousMatchButton_Click"
                        ToolTip.Tip="Previous match (Shift+Enter)"
                        Width="26" Height="26"
                        Margin="2,0,0,0"
                        Background="Transparent"
                        Foreground="#cccccc">
                    <mi:MaterialIcon Kind="ChevronUp" Width="14" Height="14" />
                </Button>
                <Button x:Name="NextMatchButton"
                        Click="NextMatchButton_Click"
                        ToolTip.Tip="Next match (Enter)"
                        Width="26" Height="26"
                        Margin="2,0,0,0"
                        Background="Transparent"
                        Foreground="#cccccc">
                    <mi:MaterialIcon Kind="ChevronDown" Width="14" Height="14" />
                </Button>
                <Button x:Name="CloseSearchButton"
                        Click="CloseSearchButton_Click"
                        ToolTip.Tip="Close (Escape)"
                        Width="26" Height="26"
                        Margin="4,0,0,0"
                        Background="Transparent"
                        Foreground="#cccccc">
                    <mi:MaterialIcon Kind="Close" Width="12" Height="12" />
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
