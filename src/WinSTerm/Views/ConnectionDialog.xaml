<mah:MetroWindow x:Class="WinSTerm.Views.ConnectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:converters="clr-namespace:WinSTerm.Converters"
        xmlns:models="clr-namespace:WinSTerm.Models"
        Title="{Binding IsEditMode, Converter={StaticResource EditModeTitleConverter}}"
        Width="550" Height="600"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        TitleCharacterCasing="Normal"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        BorderThickness="1">

    <mah:MetroWindow.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
    </mah:MetroWindow.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tabbed content -->
        <TabControl Grid.Row="0">

            <!-- ==================== General Tab ==================== -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,12,8,8">
                    <StackPanel>

                        <!-- Session Name -->
                        <TextBox Margin="0,0,0,12"
                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 mah:TextBoxHelper.Watermark="Session name (optional)"
                                 mah:TextBoxHelper.ClearTextButton="True"/>

                        <!-- Description -->
                        <TextBox Margin="0,0,0,12" Height="60"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 mah:TextBoxHelper.Watermark="Notes / description (optional)"/>

                        <!-- Host + Port side by side -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" Margin="0,0,8,0"
                                     Text="{Binding Host, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                     mah:TextBoxHelper.Watermark="Hostname or IP"/>

                            <mah:NumericUpDown Grid.Column="1"
                                               Value="{Binding Port, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                               Minimum="1" Maximum="65535"
                                               mah:TextBoxHelper.Watermark="Port"
                                               NumericInputMode="Numbers"/>
                        </Grid>

                        <!-- Username -->
                        <TextBox Margin="0,0,0,12"
                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                 mah:TextBoxHelper.Watermark="Username"/>

                        <!-- Auth Method -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="Auth Method:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <RadioButton Content="Password" VerticalAlignment="Center" Margin="0,0,16,0"
                                         IsChecked="{Binding IsPasswordAuth, Mode=OneWay}"
                                         Checked="PasswordRadio_Checked"/>
                            <RadioButton Content="Private Key" VerticalAlignment="Center"
                                         IsChecked="{Binding IsPrivateKeyAuth, Mode=OneWay}"
                                         Checked="PrivateKeyRadio_Checked"/>
                        </StackPanel>

                        <!-- Password -->
                        <PasswordBox Margin="0,0,0,12"
                                     x:Name="PasswordField"
                                     mah:TextBoxHelper.Watermark="Password (optional, saved encrypted)"
                                     PasswordChanged="PasswordField_PasswordChanged"
                                     Visibility="{Binding IsPasswordAuth, Converter={StaticResource BoolToVis}}"/>

                        <!-- Private Key Path + Browse -->
                        <Grid Margin="0,0,0,12"
                              Visibility="{Binding IsPrivateKeyAuth, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" Margin="0,0,8,0"
                                     Text="{Binding PrivateKeyPath, UpdateSourceTrigger=PropertyChanged}"
                                     mah:TextBoxHelper.Watermark="Path to private key file"
                                     IsReadOnly="True"/>

                            <Button Grid.Column="1" Command="{Binding BrowseKeyCommand}"
                                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                                    Width="36" Height="36" ToolTip="Browse for key file">
                                <iconPacks:PackIconMaterial Kind="FolderOpen" Width="16" Height="16"/>
                            </Button>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== Terminal Tab ==================== -->
            <TabItem Header="Terminal">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,12,8,8">
                    <StackPanel>

                        <!-- Terminal Type -->
                        <TextBlock Text="Terminal Type" Margin="0,0,0,4"
                                   Foreground="{DynamicResource MahApps.Brushes.Gray5}"/>
                        <ComboBox Margin="0,0,0,16"
                                  ItemsSource="{Binding TerminalTypes}"
                                  SelectedItem="{Binding TerminalType}"/>

                        <!-- Startup Command -->
                        <TextBlock Text="Startup Command" Margin="0,0,0,4"
                                   Foreground="{DynamicResource MahApps.Brushes.Gray5}"/>
                        <TextBox Margin="0,0,0,16"
                                 Text="{Binding StartupCommand, UpdateSourceTrigger=PropertyChanged}"
                                 mah:TextBoxHelper.Watermark="e.g., cd /var/log &amp;&amp; ls -la"/>

                        <!-- Remote Directory -->
                        <TextBlock Text="Remote Directory" Margin="0,0,0,4"
                                   Foreground="{DynamicResource MahApps.Brushes.Gray5}"/>
                        <TextBox Margin="0,0,0,16"
                                 Text="{Binding RemoteDirectory, UpdateSourceTrigger=PropertyChanged}"
                                 mah:TextBoxHelper.Watermark="Initial SFTP directory"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== Network Tab ==================== -->
            <TabItem Header="Network">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,12,8,8">
                    <StackPanel>

                        <!-- Keep-Alive Interval -->
                        <TextBlock Text="Keep-Alive Interval (seconds, 0 = disabled)" Margin="0,0,0,4"
                                   Foreground="{DynamicResource MahApps.Brushes.Gray5}"/>
                        <mah:NumericUpDown Margin="0,0,0,16"
                                           Value="{Binding KeepAliveInterval}"
                                           Minimum="0" Maximum="300"
                                           NumericInputMode="Numbers"/>

                        <!-- Compression -->
                        <mah:ToggleSwitch Margin="0,0,0,20"
                                          Header="Enable Compression"
                                          IsOn="{Binding EnableCompression}"/>

                        <!-- Jump Host Section -->
                        <TextBlock Text="SSH GATEWAY / JUMP HOST"
                                   FontWeight="SemiBold" Margin="0,0,0,8"
                                   Foreground="{DynamicResource MahApps.Brushes.Accent}"/>
                        <Separator Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" Margin="0,0,8,0"
                                     Text="{Binding JumpHost, UpdateSourceTrigger=PropertyChanged}"
                                     mah:TextBoxHelper.Watermark="Jump host"/>

                            <mah:NumericUpDown Grid.Column="1"
                                               Value="{Binding JumpPort, UpdateSourceTrigger=PropertyChanged}"
                                               Minimum="1" Maximum="65535"
                                               mah:TextBoxHelper.Watermark="Port"
                                               NumericInputMode="Numbers"/>
                        </Grid>

                        <TextBox Margin="0,0,0,20"
                                 Text="{Binding JumpUsername, UpdateSourceTrigger=PropertyChanged}"
                                 mah:TextBoxHelper.Watermark="Jump host username"/>

                        <!-- Proxy Section -->
                        <TextBlock Text="PROXY"
                                   FontWeight="SemiBold" Margin="0,0,0,8"
                                   Foreground="{DynamicResource MahApps.Brushes.Accent}"/>
                        <Separator Margin="0,0,0,12"/>

                        <TextBlock Text="Proxy Type" Margin="0,0,0,4"
                                   Foreground="{DynamicResource MahApps.Brushes.Gray5}"/>
                        <ComboBox Margin="0,0,0,12"
                                  SelectedItem="{Binding SelectedProxyType}"
                                  ItemsSource="{Binding Source={x:Static models:ProxyType.None},
                                      Converter={x:Static converters:EnumValuesConverter.Instance}}"/>

                        <!-- Proxy Host + Port (visible when proxy enabled) -->
                        <Grid Margin="0,0,0,12"
                              Visibility="{Binding IsProxyEnabled, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" Margin="0,0,8,0"
                                     Text="{Binding ProxyHost, UpdateSourceTrigger=PropertyChanged}"
                                     mah:TextBoxHelper.Watermark="Proxy host"/>

                            <mah:NumericUpDown Grid.Column="1"
                                               Value="{Binding ProxyPort, UpdateSourceTrigger=PropertyChanged}"
                                               Minimum="1" Maximum="65535"
                                               mah:TextBoxHelper.Watermark="Port"
                                               NumericInputMode="Numbers"/>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- Buttons at bottom, outside tabs -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Save" MinWidth="80" Margin="0,0,8,0"
                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                    Command="{Binding SaveCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=mah:MetroWindow}}"/>
            <Button Content="Cancel" MinWidth="80"
                    Style="{DynamicResource MahApps.Styles.Button.Square}"
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=mah:MetroWindow}}"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>