<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="WinSTerm.Views.SnippetEditDialog"
        x:CompileBindings="False"
        Title="New Snippet"
        Width="450" Height="400"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Name -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Name *" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="NameBox"
                     Watermark="e.g. Check disk usage"/>
        </StackPanel>

        <!-- Command -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Command *" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="CommandBox"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     Height="100"
                     Watermark="e.g. df -h"
                     FontFamily="Consolas"/>
        </StackPanel>

        <!-- Description -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="Description" Margin="0,0,0,4"/>
            <TextBox x:Name="DescriptionBox"
                     Watermark="Optional description"/>
        </StackPanel>

        <!-- Validation message -->
        <TextBlock Grid.Row="3" x:Name="ValidationMessage"
                   Foreground="Red" Margin="0,0,0,8"
                   IsVisible="False"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" MinWidth="80" Margin="0,0,8,0"
                    Classes="accent"
                    Click="OkButton_Click"/>
            <Button Content="Cancel" MinWidth="80"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
