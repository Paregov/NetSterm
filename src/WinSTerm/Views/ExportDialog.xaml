<mah:MetroWindow x:Class="WinSTerm.Views.ExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:views="clr-namespace:WinSTerm.Views"
        Title="Export Configuration"
        Width="500" Height="550"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        TitleCharacterCasing="Normal"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        BorderThickness="1">

    <mah:MetroWindow.Resources>
        <!-- HierarchicalDataTemplate for ExportTreeItem with tri-state CheckBox -->
        <HierarchicalDataTemplate DataType="{x:Type views:ExportTreeItem}"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="2,1">
                <CheckBox IsChecked="{Binding IsChecked}"
                          IsThreeState="True"
                          VerticalAlignment="Center"/>
                <iconPacks:PackIconMaterial Kind="{Binding IsFolder,
                    Converter={StaticResource FolderIconConverter}}"
                    Width="14" Height="14"
                    Margin="4,0,4,0"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource MahApps.Brushes.AccentBase}"/>
                <TextBlock Text="{Binding Name}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <!-- Converter: IsFolder -> icon kind -->
        <views:BoolToFolderIconConverter x:Key="FolderIconConverter"/>
    </mah:MetroWindow.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Select items to export:"
                   FontSize="14" FontWeight="SemiBold"
                   Margin="0,0,0,8"/>

        <!-- Tree view -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource MahApps.Brushes.Gray6}"
                BorderThickness="1"
                CornerRadius="2">
            <TreeView ItemsSource="{Binding TreeItems}"
                      BorderThickness="0"
                      Padding="4">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem"
                           BasedOn="{StaticResource {x:Type TreeViewItem}}">
                        <Setter Property="IsExpanded" Value="True"/>
                    </Style>
                </TreeView.ItemContainerStyle>
            </TreeView>
        </Border>

        <!-- Options section -->
        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock Text="Options"
                       FontSize="13" FontWeight="SemiBold"
                       Margin="0,0,0,6"/>

            <CheckBox Content="Include passwords"
                      IsChecked="{Binding IncludePasswords}"
                      Margin="0,2"/>
            <TextBlock Text="⚠ Passwords will be stored in plaintext. Only use for personal backups."
                       FontSize="11"
                       Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                       Margin="20,0,0,4"
                       TextWrapping="Wrap"/>

            <CheckBox Content="Include private key files"
                      IsChecked="{Binding IncludePrivateKeys}"
                      Margin="0,2"/>
        </StackPanel>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Export"
                    Width="90" Height="32"
                    Click="OkButton_Click"
                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                    Margin="0,0,8,0"/>
            <Button Content="Cancel"
                    Width="90" Height="32"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
