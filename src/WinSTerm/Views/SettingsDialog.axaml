<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        x:Class="WinSTerm.Views.SettingsDialog"
        x:CompileBindings="False"
        Title="Settings"
        Width="550" Height="550"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tab Control -->
        <TabControl Grid.Row="0">

            <!-- Terminal Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <mi:MaterialIcon Kind="Console" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Terminal" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <!-- Font Family -->
                        <TextBlock Text="Font Family" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding FontFamilies}"
                                  SelectedItem="{Binding FontFamily}"
                                  Margin="0,0,0,16"/>

                        <!-- Font Size -->
                        <TextBlock Text="Font Size" Margin="0,0,0,4"/>
                        <NumericUpDown Value="{Binding FontSize}"
                                       Minimum="8" Maximum="32"
                                       FormatString="0"
                                       Margin="0,0,0,16"/>

                        <!-- Scrollback Lines -->
                        <TextBlock Text="Scrollback Lines" Margin="0,0,0,4"/>
                        <NumericUpDown Value="{Binding ScrollbackLines}"
                                       Minimum="1000" Maximum="100000"
                                       Increment="1000"
                                       FormatString="0"
                                       Margin="0,0,0,16"/>

                        <!-- Cursor Style -->
                        <TextBlock Text="Cursor Style" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding CursorStyles}"
                                  SelectedItem="{Binding CursorStyle}"
                                  Margin="0,0,0,16"/>

                        <!-- Cursor Blink -->
                        <ToggleSwitch IsChecked="{Binding CursorBlink}"
                                      Content="Cursor Blink"
                                      Margin="0,0,0,8"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- SSH Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <mi:MaterialIcon Kind="ServerNetwork" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="SSH" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <!-- Keep-Alive Interval -->
                        <TextBlock Text="Default Keep-Alive Interval (seconds)" Margin="0,0,0,4"/>
                        <NumericUpDown Value="{Binding DefaultKeepAliveSeconds}"
                                       Minimum="0" Maximum="300"
                                       FormatString="0"
                                       Margin="0,0,0,16"/>

                        <!-- Connection Timeout -->
                        <TextBlock Text="Connection Timeout (seconds)" Margin="0,0,0,4"/>
                        <NumericUpDown Value="{Binding ConnectionTimeoutSeconds}"
                                       Minimum="5" Maximum="120"
                                       FormatString="0"
                                       Margin="0,0,0,16"/>

                        <!-- Compression -->
                        <ToggleSwitch IsChecked="{Binding DefaultCompression}"
                                      Content="Enable Compression by Default"
                                      Margin="0,0,0,8"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- General Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <mi:MaterialIcon Kind="Cog" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="General" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <!-- Show Status Bar -->
                        <ToggleSwitch IsChecked="{Binding ShowStatusBar}"
                                      Content="Show Status Bar"
                                      Margin="0,0,0,16"/>

                        <!-- Confirm on Close Tab -->
                        <ToggleSwitch IsChecked="{Binding ConfirmOnCloseTab}"
                                      Content="Confirm on Close Tab"
                                      Margin="0,0,0,16"/>

                        <!-- Confirm on Exit -->
                        <ToggleSwitch IsChecked="{Binding ConfirmOnExit}"
                                      Content="Confirm on Exit"
                                      Margin="0,0,0,16"/>

                        <!-- Default SFTP Local Directory -->
                        <TextBlock Text="Default Local SFTP Directory" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding DefaultLocalDirectory}"
                                     Margin="0,0,8,0"
                                     IsReadOnly="True"/>
                            <Button Grid.Column="1"
                                    Command="{Binding BrowseLocalDirectoryCommand}"
                                    Classes="accent"
                                    Width="36" Height="36"
                                    ToolTip.Tip="Browse for directory">
                                <mi:MaterialIcon Kind="FolderOpen" Width="16" Height="16"/>
                            </Button>
                        </Grid>

                        <!-- Show Hidden Files -->
                        <ToggleSwitch IsChecked="{Binding ShowHiddenFiles}"
                                      Content="Show Hidden Files in SFTP"
                                      Margin="0,0,0,8"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Security Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <mi:MaterialIcon Kind="ShieldLock" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Security" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <TextBlock Text="Master Password" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="When enabled, a master password is required each time you start WinSTerm. This protects your saved connection passwords from unauthorized access."
                                   TextWrapping="Wrap" Opacity="0.5" FontSize="12" Margin="0,0,0,16"/>

                        <ToggleSwitch x:Name="MasterPasswordToggle"
                                      IsChecked="{Binding IsMasterPasswordEnabled}"
                                      Content="Require master password on startup"
                                      Margin="0,0,0,16"/>

                        <Button Content="Change Master Password"
                                Click="ChangeMasterPassword_Click"
                                HorizontalAlignment="Left"
                                MinWidth="200" Padding="12,6"
                                IsVisible="{Binding IsMasterPasswordEnabled}"
                                Margin="0,0,0,8"/>

                        <TextBlock x:Name="SecurityStatusText"
                                   Foreground="#27AE60"
                                   FontSize="12"
                                   IsVisible="False" Margin="0,8,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Save" MinWidth="80" Margin="0,0,8,0"
                    Classes="accent"
                    Command="{Binding SaveCommand}"
                    CommandParameter="{Binding $parent[Window]}"/>
            <Button Content="Cancel" MinWidth="80"
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding $parent[Window]}"/>
        </StackPanel>
    </Grid>
</Window>
