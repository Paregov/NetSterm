<mah:MetroWindow x:Class="WinSTerm.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Settings"
        Width="550" Height="550"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        TitleCharacterCasing="Normal"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        BorderThickness="1">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tab Control -->
        <TabControl Grid.Row="0">

            <!-- Terminal Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Console" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Terminal" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel Margin="8">
                        <!-- Font Family -->
                        <TextBlock Text="Font Family" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding FontFamilies}"
                                  SelectedItem="{Binding FontFamily}"
                                  Margin="0,0,0,16"/>

                        <!-- Font Size -->
                        <TextBlock Text="Font Size" Margin="0,0,0,4"/>
                        <mah:NumericUpDown Value="{Binding FontSize}"
                                           Minimum="8" Maximum="32"
                                           NumericInputMode="Numbers"
                                           Margin="0,0,0,16"/>

                        <!-- Scrollback Lines -->
                        <TextBlock Text="Scrollback Lines" Margin="0,0,0,4"/>
                        <mah:NumericUpDown Value="{Binding ScrollbackLines}"
                                           Minimum="1000" Maximum="100000"
                                           Interval="1000"
                                           NumericInputMode="Numbers"
                                           Margin="0,0,0,16"/>

                        <!-- Cursor Style -->
                        <TextBlock Text="Cursor Style" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding CursorStyles}"
                                  SelectedItem="{Binding CursorStyle}"
                                  Margin="0,0,0,16"/>

                        <!-- Cursor Blink -->
                        <mah:ToggleSwitch IsOn="{Binding CursorBlink}"
                                          Content="Cursor Blink"
                                          Margin="0,0,0,8"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- SSH Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ServerNetwork" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="SSH" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel Margin="8">
                        <!-- Keep-Alive Interval -->
                        <TextBlock Text="Default Keep-Alive Interval (seconds)" Margin="0,0,0,4"/>
                        <mah:NumericUpDown Value="{Binding DefaultKeepAliveSeconds}"
                                           Minimum="0" Maximum="300"
                                           NumericInputMode="Numbers"
                                           Margin="0,0,0,16"/>

                        <!-- Connection Timeout -->
                        <TextBlock Text="Connection Timeout (seconds)" Margin="0,0,0,4"/>
                        <mah:NumericUpDown Value="{Binding ConnectionTimeoutSeconds}"
                                           Minimum="5" Maximum="120"
                                           NumericInputMode="Numbers"
                                           Margin="0,0,0,16"/>

                        <!-- Compression -->
                        <mah:ToggleSwitch IsOn="{Binding DefaultCompression}"
                                          Content="Enable Compression by Default"
                                          Margin="0,0,0,8"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- General Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Cog" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="General" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel Margin="8">
                        <!-- Show Status Bar -->
                        <mah:ToggleSwitch IsOn="{Binding ShowStatusBar}"
                                          Content="Show Status Bar"
                                          Margin="0,0,0,16"/>

                        <!-- Confirm on Close Tab -->
                        <mah:ToggleSwitch IsOn="{Binding ConfirmOnCloseTab}"
                                          Content="Confirm on Close Tab"
                                          Margin="0,0,0,16"/>

                        <!-- Confirm on Exit -->
                        <mah:ToggleSwitch IsOn="{Binding ConfirmOnExit}"
                                          Content="Confirm on Exit"
                                          Margin="0,0,0,16"/>

                        <!-- Default SFTP Local Directory -->
                        <TextBlock Text="Default Local SFTP Directory" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding DefaultLocalDirectory, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,8,0"
                                     IsReadOnly="True"/>
                            <Button Grid.Column="1"
                                    Command="{Binding BrowseLocalDirectoryCommand}"
                                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                                    Width="36" Height="36"
                                    ToolTip="Browse for directory">
                                <iconPacks:PackIconMaterial Kind="FolderOpen" Width="16" Height="16"/>
                            </Button>
                        </Grid>

                        <!-- Show Hidden Files -->
                        <mah:ToggleSwitch IsOn="{Binding ShowHiddenFiles}"
                                          Content="Show Hidden Files in SFTP"
                                          Margin="0,0,0,8"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Save" MinWidth="80" Margin="0,0,8,0"
                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                    Command="{Binding SaveCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=mah:MetroWindow}}"/>
            <Button Content="Cancel" MinWidth="80"
                    Style="{DynamicResource MahApps.Styles.Button.Square}"
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=mah:MetroWindow}}"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
