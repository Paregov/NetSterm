<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:converters="clr-namespace:WinSTerm.Converters"
        xmlns:models="clr-namespace:WinSTerm.Models"
        x:Class="WinSTerm.Views.ConnectionDialog"
        x:CompileBindings="False"
        Title="{Binding IsEditMode, Converter={StaticResource EditModeTitleConverter}}"
        Width="550" Height="600"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tabbed content -->
        <TabControl Grid.Row="0">

            <!-- ==================== General Tab ==================== -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,12,8,8">

                        <!-- Session Name -->
                        <TextBox Margin="0,0,0,12"
                                 Text="{Binding Name}"
                                 Watermark="Session name (optional)"/>

                        <!-- Description -->
                        <TextBox Margin="0,0,0,12" Height="60"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 Text="{Binding Description}"
                                 Watermark="Notes / description (optional)"/>

                        <!-- Host + Port side by side -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" Margin="0,0,8,0"
                                     Text="{Binding Host}"
                                     Watermark="Hostname or IP"/>

                            <NumericUpDown Grid.Column="1"
                                           Value="{Binding Port}"
                                           Minimum="1" Maximum="65535"
                                           FormatString="0"
                                           Watermark="Port"/>
                        </Grid>

                        <!-- Username -->
                        <TextBox Margin="0,0,0,12"
                                 Text="{Binding Username}"
                                 Watermark="Username"/>

                        <!-- Auth Method -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="Auth Method:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <RadioButton Content="Password" VerticalAlignment="Center" Margin="0,0,16,0"
                                         IsChecked="{Binding IsPasswordAuth, Mode=OneWay}"
                                         Click="PasswordRadio_Click"/>
                            <RadioButton Content="Private Key" VerticalAlignment="Center"
                                         IsChecked="{Binding IsPrivateKeyAuth, Mode=OneWay}"
                                         Click="PrivateKeyRadio_Click"/>
                        </StackPanel>

                        <!-- Password -->
                        <TextBox Margin="0,0,0,12"
                                 PasswordChar="&#x25CF;"
                                 Text="{Binding Password}"
                                 Watermark="Password (optional, saved encrypted)"
                                 IsVisible="{Binding IsPasswordAuth}"/>

                        <!-- Private Key Path + Browse -->
                        <Grid Margin="0,0,0,12"
                              IsVisible="{Binding IsPrivateKeyAuth}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" Margin="0,0,8,0"
                                     Text="{Binding PrivateKeyPath}"
                                     Watermark="Path to private key file"
                                     IsReadOnly="True"/>

                            <Button Grid.Column="1" Command="{Binding BrowseKeyCommand}"
                                    Classes="accent"
                                    Width="36" Height="36"
                                    ToolTip.Tip="Browse for key file">
                                <mi:MaterialIcon Kind="FolderOpen" Width="16" Height="16"/>
                            </Button>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== Terminal Tab ==================== -->
            <TabItem Header="Terminal">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,12,8,8">

                        <!-- Terminal Type -->
                        <TextBlock Text="Terminal Type" Margin="0,0,0,4" Opacity="0.6"/>
                        <ComboBox Margin="0,0,0,16"
                                  ItemsSource="{Binding TerminalTypes}"
                                  SelectedItem="{Binding TerminalType}"/>

                        <!-- Startup Command -->
                        <TextBlock Text="Startup Command" Margin="0,0,0,4" Opacity="0.6"/>
                        <TextBox Margin="0,0,0,16"
                                 Text="{Binding StartupCommand}"
                                 Watermark="e.g., cd /var/log &amp;&amp; ls -la"/>

                        <!-- Remote Directory -->
                        <TextBlock Text="Remote Directory" Margin="0,0,0,4" Opacity="0.6"/>
                        <TextBox Margin="0,0,0,16"
                                 Text="{Binding RemoteDirectory}"
                                 Watermark="Initial SFTP directory"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== Network Tab ==================== -->
            <TabItem Header="Network">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,12,8,8">

                        <!-- Keep-Alive Interval -->
                        <TextBlock Text="Keep-Alive Interval (seconds, 0 = disabled)" Margin="0,0,0,4"
                                   Opacity="0.6"/>
                        <NumericUpDown Margin="0,0,0,16"
                                       Value="{Binding KeepAliveInterval}"
                                       Minimum="0" Maximum="300"
                                       FormatString="0"/>

                        <!-- Compression -->
                        <ToggleSwitch Margin="0,0,0,20"
                                      Content="Enable Compression"
                                      IsChecked="{Binding EnableCompression}"/>

                        <!-- Jump Host Section -->
                        <TextBlock Text="SSH GATEWAY / JUMP HOST"
                                   FontWeight="SemiBold" Margin="0,0,0,8"
                                   Foreground="#0078D7"/>
                        <Separator Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" Margin="0,0,8,0"
                                     Text="{Binding JumpHost}"
                                     Watermark="Jump host"/>

                            <NumericUpDown Grid.Column="1"
                                           Value="{Binding JumpPort}"
                                           Minimum="1" Maximum="65535"
                                           FormatString="0"
                                           Watermark="Port"/>
                        </Grid>

                        <TextBox Margin="0,0,0,20"
                                 Text="{Binding JumpUsername}"
                                 Watermark="Jump host username"/>

                        <!-- Proxy Section -->
                        <TextBlock Text="PROXY"
                                   FontWeight="SemiBold" Margin="0,0,0,8"
                                   Foreground="#0078D7"/>
                        <Separator Margin="0,0,0,12"/>

                        <TextBlock Text="Proxy Type" Margin="0,0,0,4" Opacity="0.6"/>
                        <ComboBox Margin="0,0,0,12"
                                  SelectedItem="{Binding SelectedProxyType}"
                                  ItemsSource="{Binding Source={x:Static models:ProxyType.None},
                                      Converter={x:Static converters:EnumValuesConverter.Instance}}"/>

                        <!-- Proxy Host + Port (visible when proxy enabled) -->
                        <Grid Margin="0,0,0,12"
                              IsVisible="{Binding IsProxyEnabled}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" Margin="0,0,8,0"
                                     Text="{Binding ProxyHost}"
                                     Watermark="Proxy host"/>

                            <NumericUpDown Grid.Column="1"
                                           Value="{Binding ProxyPort}"
                                           Minimum="1" Maximum="65535"
                                           FormatString="0"
                                           Watermark="Port"/>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- Buttons at bottom, outside tabs -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Save" MinWidth="80" Margin="0,0,8,0"
                    Classes="accent"
                    Command="{Binding SaveCommand}"
                    CommandParameter="{Binding $parent[Window]}"/>
            <Button Content="Cancel" MinWidth="80"
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding $parent[Window]}"/>
        </StackPanel>
    </Grid>
</Window>
