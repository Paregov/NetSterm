<UserControl x:Class="WinSTerm.Views.TerminalControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    PreviewKeyDown="OnPreviewKeyDown">
    <Grid>
        <wv2:WebView2 x:Name="TerminalWebView" 
                       DefaultBackgroundColor="#1E1E1E" />

        <!-- Search overlay bar -->
        <Border x:Name="SearchBar"
                Visibility="Collapsed"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,4,16,0"
                Background="{StaticResource SidebarBackground}"
                BorderBrush="{StaticResource SidebarBorder}"
                BorderThickness="1"
                CornerRadius="2"
                Padding="6,4">
            <StackPanel Orientation="Horizontal">
                <iconPacks:PackIconMaterial Kind="Magnify"
                                           Width="14" Height="14"
                                           VerticalAlignment="Center"
                                           Foreground="#999999"
                                           Margin="0,0,6,0" />
                <TextBox x:Name="SearchTextBox"
                         Width="200"
                         FontSize="13"
                         VerticalContentAlignment="Center"
                         mah:TextBoxHelper.Watermark="Find in terminal..."
                         mah:TextBoxHelper.ClearTextButton="True"
                         Background="#3c3c3c"
                         Foreground="#cccccc"
                         BorderBrush="#3e3e42"
                         CaretBrush="#cccccc"
                         TextChanged="SearchTextBox_TextChanged"
                         PreviewKeyDown="SearchTextBox_PreviewKeyDown" />
                <Button x:Name="PreviousMatchButton"
                        Click="PreviousMatchButton_Click"
                        ToolTip="Previous match (Shift+Enter)"
                        Style="{StaticResource MahApps.Styles.Button.Chromeless}"
                        Width="26" Height="26"
                        Margin="2,0,0,0"
                        Foreground="#cccccc">
                    <iconPacks:PackIconMaterial Kind="ChevronUp" Width="14" Height="14" />
                </Button>
                <Button x:Name="NextMatchButton"
                        Click="NextMatchButton_Click"
                        ToolTip="Next match (Enter)"
                        Style="{StaticResource MahApps.Styles.Button.Chromeless}"
                        Width="26" Height="26"
                        Margin="2,0,0,0"
                        Foreground="#cccccc">
                    <iconPacks:PackIconMaterial Kind="ChevronDown" Width="14" Height="14" />
                </Button>
                <Button x:Name="CloseSearchButton"
                        Click="CloseSearchButton_Click"
                        ToolTip="Close (Escape)"
                        Style="{StaticResource MahApps.Styles.Button.Chromeless}"
                        Width="26" Height="26"
                        Margin="4,0,0,0"
                        Foreground="#cccccc">
                    <iconPacks:PackIconMaterial Kind="Close" Width="12" Height="12" />
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
