<mah:MetroWindow x:Class="WinSTerm.Views.SetMasterPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        Title="Set Master Password"
        Width="400" Height="280"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        TitleCharacterCasing="Normal"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        BorderThickness="1">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Current Password (visible in Change/Verify mode) -->
        <StackPanel Grid.Row="0" x:Name="CurrentPasswordPanel" Visibility="Collapsed" Margin="0,0,0,12">
            <TextBlock Text="Current Password" Margin="0,0,0,4" FontSize="12"/>
            <PasswordBox x:Name="CurrentPasswordField"
                         mah:TextBoxHelper.Watermark="Current password"
                         KeyDown="PasswordField_KeyDown"/>
        </StackPanel>

        <!-- New Password -->
        <StackPanel Grid.Row="1" x:Name="NewPasswordPanel" Margin="0,0,0,12">
            <TextBlock Text="New Password" Margin="0,0,0,4" FontSize="12"/>
            <PasswordBox x:Name="NewPasswordField"
                         mah:TextBoxHelper.Watermark="Enter new password"
                         KeyDown="PasswordField_KeyDown"/>
        </StackPanel>

        <!-- Confirm Password -->
        <StackPanel Grid.Row="2" x:Name="ConfirmPasswordPanel" Margin="0,0,0,12">
            <TextBlock Text="Confirm Password" Margin="0,0,0,4" FontSize="12"/>
            <PasswordBox x:Name="ConfirmPasswordField"
                         mah:TextBoxHelper.Watermark="Confirm new password"
                         KeyDown="PasswordField_KeyDown"/>
        </StackPanel>

        <!-- Error text -->
        <TextBlock Grid.Row="3" x:Name="ErrorText"
                   Foreground="{StaticResource ErrorBrush}"
                   FontSize="12"
                   Visibility="Collapsed"
                   TextWrapping="Wrap"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" MinWidth="80" Margin="0,0,8,0"
                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                    Click="OkButton_Click"/>
            <Button Content="Cancel" MinWidth="80"
                    Style="{DynamicResource MahApps.Styles.Button.Square}"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
