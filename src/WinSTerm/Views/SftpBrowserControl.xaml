<UserControl x:Class="WinSTerm.Views.SftpBrowserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:vm="clr-namespace:WinSTerm.ViewModels"
             xmlns:converters="clr-namespace:WinSTerm.Converters"
             xmlns:models="clr-namespace:WinSTerm.Models"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:SftpBrowserViewModel, IsDesignTimeCreatable=False}"
             Background="{DynamicResource MahApps.Brushes.ThemeBackground}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:FileSizeConverter x:Key="FileSizeConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Dual-pane file browser -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- LOCAL PANE (Left) -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Local path bar -->
                <Grid Grid.Row="0" Margin="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Margin="0,0,4,0"
                            Command="{Binding NavigateLocalUpCommand}"
                            Style="{DynamicResource MahApps.Styles.Button.Square}"
                            Width="32" Height="32" ToolTip="Parent Directory"
                            Padding="0">
                        <iconPacks:PackIconMaterial Kind="ArrowUp" Width="14" Height="14"/>
                    </Button>

                    <TextBox Grid.Column="1" Margin="0,0,4,0"
                             Text="{Binding LocalPath, UpdateSourceTrigger=PropertyChanged}"
                             mah:TextBoxHelper.Watermark="Local path"
                             VerticalContentAlignment="Center"
                             x:Name="LocalPathBox"
                             KeyDown="LocalPathBox_KeyDown"/>

                    <Button Grid.Column="2"
                            Command="{Binding RefreshLocalCommand}"
                            Style="{DynamicResource MahApps.Styles.Button.Square}"
                            Width="32" Height="32" ToolTip="Refresh"
                            Padding="0">
                        <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14"/>
                    </Button>
                </Grid>

                <!-- Local file list -->
                <DataGrid Grid.Row="1" Margin="4,0,4,4"
                          x:Name="LocalFilesGrid"
                          ItemsSource="{Binding LocalFiles}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Extended"
                          SelectionUnit="FullRow"
                          CanUserReorderColumns="False"
                          CanUserResizeRows="False"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column"
                          MouseDoubleClick="LocalFilesGrid_MouseDoubleClick"
                          SelectionChanged="LocalFilesGrid_SelectionChanged"
                          Style="{DynamicResource MahApps.Styles.DataGrid}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="30" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <iconPacks:PackIconMaterial Kind="Folder" Width="14" Height="14"
                                            Foreground="#DCBB67" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <iconPacks:PackIconMaterial.Style>
                                                <Style TargetType="iconPacks:PackIconMaterial">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </iconPacks:PackIconMaterial.Style>
                                        </iconPacks:PackIconMaterial>
                                        <iconPacks:PackIconMaterial Kind="FileOutline" Width="14" Height="14"
                                            Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <iconPacks:PackIconMaterial.Style>
                                                <Style TargetType="iconPacks:PackIconMaterial">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </iconPacks:PackIconMaterial.Style>
                                        </iconPacks:PackIconMaterial>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Size" Binding="{Binding SizeDisplay}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Modified" Binding="{Binding LastModified, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Grid Splitter -->
            <GridSplitter Grid.Column="1" Width="4"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="{DynamicResource SidebarBorder}"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- REMOTE PANE (Right) -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Remote path bar -->
                <Grid Grid.Row="0" Margin="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Margin="0,0,4,0"
                            Command="{Binding NavigateRemoteUpCommand}"
                            Style="{DynamicResource MahApps.Styles.Button.Square}"
                            Width="32" Height="32" ToolTip="Parent Directory"
                            Padding="0">
                        <iconPacks:PackIconMaterial Kind="ArrowUp" Width="14" Height="14"/>
                    </Button>

                    <TextBox Grid.Column="1" Margin="0,0,4,0"
                             Text="{Binding RemotePath, UpdateSourceTrigger=PropertyChanged}"
                             mah:TextBoxHelper.Watermark="Remote path"
                             VerticalContentAlignment="Center"
                             x:Name="RemotePathBox"
                             KeyDown="RemotePathBox_KeyDown"/>

                    <Button Grid.Column="2"
                            Command="{Binding RefreshRemoteCommand}"
                            Style="{DynamicResource MahApps.Styles.Button.Square}"
                            Width="32" Height="32" ToolTip="Refresh"
                            Padding="0">
                        <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14"/>
                    </Button>
                </Grid>

                <!-- Remote file list -->
                <DataGrid Grid.Row="1" Margin="4,0,4,4"
                          x:Name="RemoteFilesGrid"
                          ItemsSource="{Binding RemoteFiles}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Extended"
                          SelectionUnit="FullRow"
                          CanUserReorderColumns="False"
                          CanUserResizeRows="False"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column"
                          MouseDoubleClick="RemoteFilesGrid_MouseDoubleClick"
                          SelectionChanged="RemoteFilesGrid_SelectionChanged"
                          Style="{DynamicResource MahApps.Styles.DataGrid}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="30" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <iconPacks:PackIconMaterial Kind="Folder" Width="14" Height="14"
                                            Foreground="#DCBB67" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <iconPacks:PackIconMaterial.Style>
                                                <Style TargetType="iconPacks:PackIconMaterial">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </iconPacks:PackIconMaterial.Style>
                                        </iconPacks:PackIconMaterial>
                                        <iconPacks:PackIconMaterial Kind="FileOutline" Width="14" Height="14"
                                            Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <iconPacks:PackIconMaterial.Style>
                                                <Style TargetType="iconPacks:PackIconMaterial">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </iconPacks:PackIconMaterial.Style>
                                        </iconPacks:PackIconMaterial>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Size" Binding="{Binding SizeDisplay}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Modified" Binding="{Binding LastModified, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- Bottom toolbar: transfers and actions -->
        <Grid Grid.Row="1" Background="{DynamicResource ToolbarBackground}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Action buttons -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,6">
                <Button Command="{Binding UploadCommand}"
                        Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                        Height="30" Padding="12,0" Margin="0,0,8,0"
                        ToolTip="Upload selected local files to remote">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Upload" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <iconPacks:PackIconMaterial Kind="ArrowRight" Width="12" Height="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding DownloadCommand}"
                        Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                        Height="30" Padding="12,0" Margin="0,0,8,0"
                        ToolTip="Download selected remote files to local">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ArrowLeft" Width="12" Height="12" VerticalAlignment="Center"/>
                        <TextBlock Text="Download" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                </Button>

                <Button Style="{DynamicResource MahApps.Styles.Button.Square}"
                        Height="30" Padding="12,0" Margin="0,0,8,0"
                        ToolTip="Create new remote folder"
                        x:Name="CreateFolderButton"
                        Click="CreateFolderButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="FolderPlus" Width="14" Height="14" VerticalAlignment="Center"/>
                        <TextBlock Text="New Folder" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                </Button>

                <!-- Busy indicator -->
                <mah:ProgressRing IsActive="{Binding IsBusy}" Width="20" Height="20"
                                  Margin="8,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Active transfer progress -->
            <ItemsControl Grid.Row="1" ItemsSource="{Binding Transfers}" Margin="8,0,8,6">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0">
                                <Grid Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="Upload" Width="12" Height="12">
                                        <iconPacks:PackIconMaterial.Style>
                                            <Style TargetType="iconPacks:PackIconMaterial">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Direction}" Value="{x:Static models:TransferDirection.Upload}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </iconPacks:PackIconMaterial.Style>
                                    </iconPacks:PackIconMaterial>
                                    <iconPacks:PackIconMaterial Kind="Download" Width="12" Height="12">
                                        <iconPacks:PackIconMaterial.Style>
                                            <Style TargetType="iconPacks:PackIconMaterial">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Direction}" Value="{x:Static models:TransferDirection.Download}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </iconPacks:PackIconMaterial.Style>
                                    </iconPacks:PackIconMaterial>
                                </Grid>
                                <TextBlock Text="{Binding FileName}" VerticalAlignment="Center"
                                           Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                                           MaxWidth="200" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <mah:MetroProgressBar Grid.Column="1" Value="{Binding ProgressPercent}"
                                                   Minimum="0" Maximum="100" Height="14"
                                                   VerticalAlignment="Center" Margin="4,0"/>

                            <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                       Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                                       Text="{Binding ProgressPercent, StringFormat='{}{0:F0}%'}"
                                       TextAlignment="Right"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</UserControl>
