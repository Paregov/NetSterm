<mah:MetroWindow x:Class="WinSTerm.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:vm="clr-namespace:WinSTerm.ViewModels"
        xmlns:converters="clr-namespace:WinSTerm.Converters"
        xmlns:views="clr-namespace:WinSTerm.Views"
        mc:Ignorable="d"
        Title="WinSTerm - SSH Terminal"
        Icon="Assets/winsterm.ico"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen"
        TitleCharacterCasing="Normal"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        BorderThickness="1">

    <mah:MetroWindow.Resources>
        <converters:ConnectionStatusToColorConverter x:Key="StatusToColor"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        <converters:NullToVisibilityConverter x:Key="NullToVis"/>
        <converters:InverseNullToVisibilityConverter x:Key="NullToCollapsed"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
        <converters:FileSizeConverter x:Key="FileSizeConverter"/>
        <converters:EqualityConverter x:Key="EqualityConverter"/>

        <!-- Sidebar tab toggle style (RadioButton as flat tab) -->
        <Style x:Key="SidebarTabStyle" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border"
                                Background="Transparent"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Padding="8,6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="BorderBrush"
                                        Value="{StaticResource AccentBlueBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter Property="Foreground" Value="#999"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3e3e42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </mah:MetroWindow.Resources>

    <DockPanel LastChildFill="True">

        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top" Background="{StaticResource ToolbarBackground}">
            <MenuItem Header="_File">
                <MenuItem Header="_New Connection" Click="NewConnection_Click">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="New _Folder" Command="{Binding AddFolderCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="FolderPlus" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Export Connections..." Click="ExportConnections_Click">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="Export" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Import Connections..." Click="ImportConnections_Click">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="Import" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Settings" Click="Settings_Click" InputGestureText="Ctrl+,">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="Cog" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Quick Connect _Bar"
                          IsCheckable="True"
                          IsChecked="{Binding IsQuickConnectVisible, Mode=TwoWay}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="ServerNetwork" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Sessions">
                <MenuItem Header="_Quick Connect" Command="{Binding QuickConnectCommand}"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About WinSTerm"/>
            </MenuItem>
        </Menu>

        <!-- Quick Connect Toolbar -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource ToolbarBackground}"
                BorderBrush="{StaticResource SidebarBorder}" BorderThickness="0,0,0,1"
                Padding="8,4"
                Visibility="{Binding IsQuickConnectVisible, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <iconPacks:PackIconMaterial Kind="ServerNetwork" VerticalAlignment="Center"
                                           Margin="0,0,6,0" Width="16" Height="16"
                                           Foreground="{StaticResource AccentBlueBrush}"/>

                <TextBlock Text="Host:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Width="180"
                         Text="{Binding QuickHost, UpdateSourceTrigger=PropertyChanged}"
                         mah:TextBoxHelper.Watermark="hostname or IP"
                         Margin="0,0,8,0"/>

                <TextBlock Text="User:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Width="120"
                         Text="{Binding QuickUsername, UpdateSourceTrigger=PropertyChanged}"
                         mah:TextBoxHelper.Watermark="username"
                         Margin="0,0,8,0"/>

                <TextBlock Text="Port:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <mah:NumericUpDown Width="80" Value="{Binding QuickPort}"
                                   Minimum="1" Maximum="65535"
                                   Margin="0,0,8,0" NumericInputMode="Numbers"/>

                <Button Click="QuickConnect_Click"
                        Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                        Padding="12,4">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Connection" Width="14" Height="14" Margin="0,0,4,0"/>
                        <TextBlock Text="Connect"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom" Background="{StaticResource StatusBarBackground}">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Information" Width="12" Height="12"
                                               Margin="0,0,4,0"
                                               Foreground="{StaticResource StatusBarForeground}"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource StatusBarForeground}"/>
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Monitor" Width="12" Height="12"
                                               Margin="0,0,4,0"
                                               Foreground="{StaticResource StatusBarForeground}"/>
                    <TextBlock Foreground="{StaticResource StatusBarForeground}">
                        <Run Text="{Binding ConnectionCount, Mode=OneWay}"/>
                        <Run Text=" session(s)"/>
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- Main Content: Sidebar + Tabs -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="150" MaxWidth="500"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Sidebar: Sessions / SFTP Toggle -->
            <Border Grid.Column="0"
                    Background="{StaticResource SidebarBackground}"
                    BorderBrush="{StaticResource SidebarBorder}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Sidebar Toggle Header -->
                    <Border DockPanel.Dock="Top"
                            Background="{StaticResource ToolbarBackground}"
                            BorderBrush="{StaticResource SidebarBorder}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <RadioButton Grid.Column="0" GroupName="SidebarTab"
                                         IsChecked="{Binding IsSessionsSidebarVisible, Mode=OneWay}"
                                         Checked="SessionsTab_Checked"
                                         Style="{StaticResource SidebarTabStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="FolderAccount" Width="12" Height="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="Sessions" FontSize="12"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Grid.Column="1" GroupName="SidebarTab"
                                         IsChecked="{Binding IsSftpSidebarVisible, Mode=OneWay}"
                                         Checked="SftpTab_Checked"
                                         Style="{StaticResource SidebarTabStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="FolderNetwork" Width="12" Height="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="SFTP" FontSize="12"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Grid.Column="2" GroupName="SidebarTab"
                                         IsChecked="{Binding IsSnippetsSidebarVisible, Mode=OneWay}"
                                         Checked="SnippetsTab_Checked"
                                         Style="{StaticResource SidebarTabStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="CodeBraces" Width="12" Height="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="Snippets" FontSize="12"/>
                                </StackPanel>
                            </RadioButton>
                        </Grid>
                    </Border>

                    <!-- Content area: Sessions and SFTP panels overlaid -->
                    <Grid>
                        <!-- ===== Sessions Panel ===== -->
                        <DockPanel Visibility="{Binding IsSessionsSidebarVisible, Converter={StaticResource BoolToVis}}">
                            <!-- Sessions toolbar -->
                            <Border DockPanel.Dock="Top" Padding="4,2"
                                    Background="{StaticResource ToolbarBackground}"
                                    BorderBrush="{StaticResource SidebarBorder}" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Command="{Binding AddFolderCommand}" ToolTip="New Folder"
                                            Style="{StaticResource MahApps.Styles.Button.Chromeless}"
                                            Padding="4" Margin="2,0">
                                        <iconPacks:PackIconMaterial Kind="FolderPlus" Width="14" Height="14"/>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- Sessions TreeView (preserved exactly) -->
                            <TreeView x:Name="SessionTreeView"
                                      ItemsSource="{Binding SessionTree}"
                                      Background="Transparent" BorderThickness="0"
                                      Padding="4"
                                      MouseDoubleClick="SessionTree_MouseDoubleClick">
                                <TreeView.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="New Connection" Click="NewConnectionFromTree_Click">
                                            <MenuItem.Icon>
                                                <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="New Folder" Click="NewFolderFromTree_Click">
                                            <MenuItem.Icon>
                                                <iconPacks:PackIconMaterial Kind="FolderPlus" Width="14" Height="14"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </TreeView.ContextMenu>
                                <TreeView.Resources>
                                    <HierarchicalDataTemplate DataType="{x:Type vm:SessionTreeItem}"
                                                               ItemsSource="{Binding Children}">
                                        <StackPanel Orientation="Horizontal" Margin="2">
                                            <StackPanel.ContextMenu>
                                                <ContextMenu>
                                                    <!-- Connection-only: Connect -->
                                                    <MenuItem Header="Connect" Click="ConnectMenuItem_Click"
                                                              Visibility="{Binding IsFolder, Converter={StaticResource InverseBoolToVis}}">
                                                        <MenuItem.Icon>
                                                            <iconPacks:PackIconMaterial Kind="Connection" Width="14" Height="14"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <!-- Folder-only: New Connection Here -->
                                                    <MenuItem Header="New Connection Here" Click="NewConnectionInFolder_Click"
                                                              Visibility="{Binding IsFolder, Converter={StaticResource BoolToVis}}">
                                                        <MenuItem.Icon>
                                                            <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <!-- Folder-only: New Subfolder -->
                                                    <MenuItem Header="New Subfolder" Click="NewSubfolderInFolder_Click"
                                                              Visibility="{Binding IsFolder, Converter={StaticResource BoolToVis}}">
                                                        <MenuItem.Icon>
                                                            <iconPacks:PackIconMaterial Kind="FolderPlus" Width="14" Height="14"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <Separator/>
                                                    <!-- Folder-only: Rename -->
                                                    <MenuItem Header="Rename" Click="RenameItem_Click"
                                                              Visibility="{Binding IsFolder, Converter={StaticResource BoolToVis}}">
                                                        <MenuItem.Icon>
                                                            <iconPacks:PackIconMaterial Kind="Pencil" Width="14" Height="14"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <!-- Connection-only: Edit -->
                                                    <MenuItem Header="Edit" Click="EditMenuItem_Click"
                                                              Visibility="{Binding IsFolder, Converter={StaticResource InverseBoolToVis}}">
                                                        <MenuItem.Icon>
                                                            <iconPacks:PackIconMaterial Kind="Pencil" Width="14" Height="14"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <Separator/>
                                                    <!-- Both: Delete -->
                                                    <MenuItem Header="Delete" Click="DeleteMenuItem_Click">
                                                        <MenuItem.Icon>
                                                            <iconPacks:PackIconMaterial Kind="Delete" Width="14" Height="14"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                </ContextMenu>
                                            </StackPanel.ContextMenu>
                                            <!-- Folder icon -->
                                            <iconPacks:PackIconMaterial Kind="Folder" Width="14" Height="14"
                                                                        Foreground="#dca756"
                                                                        Visibility="{Binding IsFolder, Converter={StaticResource BoolToVis}}"
                                                                        Margin="0,0,6,0"/>
                                            <!-- Connection icon -->
                                            <iconPacks:PackIconMaterial Kind="Console" Width="14" Height="14"
                                                                        Foreground="{StaticResource AccentBlueBrush}"
                                                                        Visibility="{Binding IsFolder, Converter={StaticResource InverseBoolToVis}}"
                                                                        Margin="0,0,6,0"/>
                                            <!-- Normal mode: display name -->
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                                       Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVis}}"/>
                                            <!-- Edit mode: editable name -->
                                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                     Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                                                     MinWidth="100" VerticalAlignment="Center"
                                                     LostFocus="TreeItemTextBox_LostFocus"
                                                     PreviewKeyDown="TreeItemTextBox_KeyDown"
                                                     Loaded="TreeItemTextBox_Loaded"/>
                                        </StackPanel>
                                    </HierarchicalDataTemplate>
                                </TreeView.Resources>
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                            </TreeView>
                        </DockPanel>

                        <!-- ===== SFTP Sidebar Panel ===== -->
                        <DockPanel Visibility="{Binding IsSftpSidebarVisible, Converter={StaticResource BoolToVis}}">
                            <!-- SFTP toolbar: path + up + refresh -->
                            <Border DockPanel.Dock="Top" Padding="4,2"
                                    Background="{StaticResource ToolbarBackground}"
                                    BorderBrush="{StaticResource SidebarBorder}" BorderThickness="0,0,0,1">
                                <DockPanel>
                                    <Button Command="{Binding SftpSidebar.RefreshCommand}"
                                            ToolTip="Refresh"
                                            Style="{StaticResource MahApps.Styles.Button.Chromeless}"
                                            Padding="4" Margin="2,0" DockPanel.Dock="Right">
                                        <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14"/>
                                    </Button>
                                    <Button Command="{Binding SftpSidebar.NavigateUpCommand}"
                                            ToolTip="Go to parent directory"
                                            Style="{StaticResource MahApps.Styles.Button.Chromeless}"
                                            Padding="4" Margin="2,0" DockPanel.Dock="Right">
                                        <iconPacks:PackIconMaterial Kind="ArrowUp" Width="14" Height="14"/>
                                    </Button>
                                    <TextBlock Text="{Binding SftpSidebar.CurrentPath}"
                                               FontSize="11" VerticalAlignment="Center"
                                               Foreground="#999" Margin="4,0"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding SftpSidebar.CurrentPath}"/>
                                </DockPanel>
                            </Border>

                            <Grid>
                                <!-- Not connected placeholder -->
                                <StackPanel Visibility="{Binding SftpSidebar.IsConnected, Converter={StaticResource InverseBoolToVis}}"
                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="FolderNetwork" Width="32" Height="32"
                                                                Foreground="#444" HorizontalAlignment="Center"
                                                                Margin="0,0,0,8"/>
                                    <TextBlock Text="Connect to a server&#x0a;to browse remote files"
                                               Foreground="#666" FontSize="12"
                                               TextAlignment="Center" TextWrapping="Wrap"/>
                                </StackPanel>

                                <!-- Connected: SFTP tree + loading overlay -->
                                <Grid Visibility="{Binding SftpSidebar.IsConnected, Converter={StaticResource BoolToVis}}">
                                    <!-- SFTP TreeView -->
                                    <TreeView x:Name="SftpTreeView"
                                              ItemsSource="{Binding SftpSidebar.RootNodes}"
                                              Background="Transparent" BorderThickness="0"
                                              Padding="4"
                                              MouseDoubleClick="SftpTree_MouseDoubleClick"
                                              AllowDrop="True"
                                              DragOver="SftpTreeView_DragOver"
                                              DragLeave="SftpTreeView_DragLeave"
                                              Drop="SftpTreeView_Drop">
                                        <TreeView.Resources>
                                            <HierarchicalDataTemplate DataType="{x:Type vm:SftpTreeNode}"
                                                                       ItemsSource="{Binding Children}">
                                                <StackPanel Orientation="Horizontal" Margin="2">
                                                    <StackPanel.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="Download" Click="SftpDownload_Click">
                                                                <MenuItem.Icon>
                                                                    <iconPacks:PackIconMaterial Kind="Download" Width="14" Height="14"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Header="Rename" Click="SftpRename_Click">
                                                                <MenuItem.Icon>
                                                                    <iconPacks:PackIconMaterial Kind="RenameBox" Width="14" Height="14"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Header="Delete" Click="SftpDelete_Click">
                                                                <MenuItem.Icon>
                                                                    <iconPacks:PackIconMaterial Kind="Delete" Width="14" Height="14"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <Separator/>
                                                            <MenuItem Header="New Folder" Click="SftpNewFolder_Click">
                                                                <MenuItem.Icon>
                                                                    <iconPacks:PackIconMaterial Kind="FolderPlus" Width="14" Height="14"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Header="Upload Files Here..." Click="SftpUploadHere_Click">
                                                                <MenuItem.Icon>
                                                                    <iconPacks:PackIconMaterial Kind="Upload" Width="14" Height="14"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                        </ContextMenu>
                                                    </StackPanel.ContextMenu>
                                                    <!-- Directory icon -->
                                                    <iconPacks:PackIconMaterial Kind="Folder" Width="14" Height="14"
                                                                                Foreground="#dca756"
                                                                                Visibility="{Binding IsDirectory, Converter={StaticResource BoolToVis}}"
                                                                                Margin="0,0,6,0"/>
                                                    <!-- File icon -->
                                                    <iconPacks:PackIconMaterial Kind="File" Width="14" Height="14"
                                                                                Foreground="#999"
                                                                                Visibility="{Binding IsDirectory, Converter={StaticResource InverseBoolToVis}}"
                                                                                Margin="0,0,6,0"/>
                                                    <!-- File name -->
                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                                    <!-- File size (files only) -->
                                                    <TextBlock Text="{Binding SizeDisplay}" VerticalAlignment="Center"
                                                               Foreground="#666" Margin="8,0,0,0" FontSize="11"
                                                               Visibility="{Binding IsDirectory, Converter={StaticResource InverseBoolToVis}}"/>
                                                </StackPanel>
                                            </HierarchicalDataTemplate>
                                        </TreeView.Resources>
                                        <TreeView.ItemContainerStyle>
                                            <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                            </Style>
                                        </TreeView.ItemContainerStyle>
                                    </TreeView>

                                    <!-- Loading overlay -->
                                    <Border Background="#80252526"
                                            Visibility="{Binding SftpSidebar.IsLoading, Converter={StaticResource BoolToVis}}"
                                            IsHitTestVisible="False">
                                        <mah:ProgressRing IsActive="{Binding SftpSidebar.IsLoading}"
                                                          Width="30" Height="30"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Grid>
                        </DockPanel>

                        <!-- ===== Snippets Sidebar Panel ===== -->
                        <DockPanel Visibility="{Binding IsSnippetsSidebarVisible, Converter={StaticResource BoolToVis}}">
                            <!-- Snippets toolbar -->
                            <Border DockPanel.Dock="Top" Padding="4,2"
                                    Background="{StaticResource ToolbarBackground}"
                                    BorderBrush="{StaticResource SidebarBorder}" BorderThickness="0,0,0,1">
                                <DockPanel>
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                        <Button ToolTip="Add Folder" Click="AddSnippetFolder_Click"
                                                Style="{StaticResource MahApps.Styles.Button.Chromeless}"
                                                Padding="4" Margin="2,0">
                                            <iconPacks:PackIconMaterial Kind="FolderPlus" Width="14" Height="14"/>
                                        </Button>
                                        <Button ToolTip="Add Snippet" Click="AddSnippet_Click"
                                                Style="{StaticResource MahApps.Styles.Button.Chromeless}"
                                                Padding="4" Margin="2,0">
                                            <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14"/>
                                        </Button>
                                    </StackPanel>
                                    <TextBlock Text="Command Snippets"
                                               FontSize="11" VerticalAlignment="Center"
                                               Foreground="#999" Margin="4,0"
                                               TextTrimming="CharacterEllipsis"/>
                                </DockPanel>
                            </Border>

                            <!-- Snippet tree -->
                            <TreeView x:Name="SnippetTreeView"
                                      ItemsSource="{Binding SnippetsSidebar.SnippetTree}"
                                      Background="Transparent" BorderThickness="0"
                                      Padding="4"
                                      MouseDoubleClick="SnippetTree_MouseDoubleClick">
                                <TreeView.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="New Snippet" Click="AddSnippetFromTree_Click">
                                            <MenuItem.Icon>
                                                <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="New Folder" Click="AddSnippetFolderFromTree_Click">
                                            <MenuItem.Icon>
                                                <iconPacks:PackIconMaterial Kind="FolderPlus" Width="14" Height="14"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </TreeView.ContextMenu>
                                <TreeView.Resources>
                                    <HierarchicalDataTemplate DataType="{x:Type vm:SnippetTreeItem}"
                                                               ItemsSource="{Binding Children}">
                                        <StackPanel Orientation="Horizontal" Margin="2">
                                            <StackPanel.ContextMenu>
                                                <ContextMenu>
                                                    <!-- Snippet-only: Execute -->
                                                    <MenuItem Header="Execute" Click="ExecuteSnippetTree_Click"
                                                              Visibility="{Binding IsFolder, Converter={StaticResource InverseBoolToVis}}">
                                                        <MenuItem.Icon>
                                                            <iconPacks:PackIconMaterial Kind="Play" Width="14" Height="14"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <!-- Folder-only: New Snippet Here -->
                                                    <MenuItem Header="New Snippet Here" Click="AddSnippetInFolder_Click"
                                                              Visibility="{Binding IsFolder, Converter={StaticResource BoolToVis}}">
                                                        <MenuItem.Icon>
                                                            <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <!-- Folder-only: New Subfolder -->
                                                    <MenuItem Header="New Subfolder" Click="AddSnippetSubfolder_Click"
                                                              Visibility="{Binding IsFolder, Converter={StaticResource BoolToVis}}">
                                                        <MenuItem.Icon>
                                                            <iconPacks:PackIconMaterial Kind="FolderPlus" Width="14" Height="14"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <Separator/>
                                                    <!-- Folder-only: Rename -->
                                                    <MenuItem Header="Rename" Click="RenameSnippetFolder_Click"
                                                              Visibility="{Binding IsFolder, Converter={StaticResource BoolToVis}}">
                                                        <MenuItem.Icon>
                                                            <iconPacks:PackIconMaterial Kind="Pencil" Width="14" Height="14"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <!-- Snippet-only: Edit -->
                                                    <MenuItem Header="Edit" Click="EditSnippetTree_Click"
                                                              Visibility="{Binding IsFolder, Converter={StaticResource InverseBoolToVis}}">
                                                        <MenuItem.Icon>
                                                            <iconPacks:PackIconMaterial Kind="Pencil" Width="14" Height="14"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <Separator/>
                                                    <!-- Both: Delete -->
                                                    <MenuItem Header="Delete" Click="DeleteSnippetTree_Click">
                                                        <MenuItem.Icon>
                                                            <iconPacks:PackIconMaterial Kind="Delete" Width="14" Height="14"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                </ContextMenu>
                                            </StackPanel.ContextMenu>
                                            <!-- Folder icon -->
                                            <iconPacks:PackIconMaterial Kind="Folder" Width="14" Height="14"
                                                                        Foreground="#dca756"
                                                                        Visibility="{Binding IsFolder, Converter={StaticResource BoolToVis}}"
                                                                        Margin="0,0,6,0"/>
                                            <!-- Snippet icon -->
                                            <iconPacks:PackIconMaterial Kind="CodeBraces" Width="14" Height="14"
                                                                        Foreground="{StaticResource AccentBlueBrush}"
                                                                        Visibility="{Binding IsFolder, Converter={StaticResource InverseBoolToVis}}"
                                                                        Margin="0,0,6,0"/>
                                            <!-- Normal mode: display name -->
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                                       Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVis}}"/>
                                            <!-- Edit mode: editable name -->
                                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                     Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                                                     MinWidth="100" VerticalAlignment="Center"
                                                     LostFocus="SnippetFolderTextBox_LostFocus"
                                                     PreviewKeyDown="SnippetFolderTextBox_KeyDown"
                                                     Loaded="SnippetFolderTextBox_Loaded"/>
                                        </StackPanel>
                                    </HierarchicalDataTemplate>
                                </TreeView.Resources>
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                            </TreeView>
                        </DockPanel>
                    </Grid>
                </DockPanel>
            </Border>

            <!-- Grid Splitter -->
            <GridSplitter Grid.Column="1" Width="3"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="{StaticResource SidebarBorder}"/>

            <!-- Center: Always-Visible Tab Bar + Content -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Always-visible tab strip -->
                <Border Grid.Row="0"
                        Background="{StaticResource ToolbarBackground}"
                        BorderBrush="{StaticResource SidebarBorder}"
                        BorderThickness="0,0,0,1">
                    <DockPanel>
                        <!-- "+" new tab button (docked right) -->
                        <Button DockPanel.Dock="Right"
                                Click="NewTabButton_Click"
                                ToolTip="New Connection"
                                Style="{StaticResource MahApps.Styles.Button.Chromeless}"
                                Padding="6,4" Margin="2"
                                VerticalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="Plus" Width="12" Height="12"
                                                        Foreground="{StaticResource AccentBlueBrush}"/>
                        </Button>

                        <!-- Tab headers (scrollable) -->
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <StackPanel Orientation="Horizontal">
                                <!-- Home tab (always first, cannot be closed) -->
                                <Border Padding="8,6" Margin="0,2,0,0" Cursor="Hand"
                                        CornerRadius="4,4,0,0"
                                        MouseLeftButtonDown="HomeTab_Click">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#2a2d2e"/>
                                                </Trigger>
                                                <DataTrigger Binding="{Binding IsHomeSelected}" Value="True">
                                                    <Setter Property="Background" Value="#1e1e1e"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Home" Width="14" Height="14"
                                                                    Foreground="{StaticResource AccentBlueBrush}"
                                                                    Margin="0,0,6,0"
                                                                    VerticalAlignment="Center"/>
                                        <TextBlock Text="Home" VerticalAlignment="Center" FontSize="12"/>
                                    </StackPanel>
                                </Border>

                                <!-- Session tabs (dynamic, from Tabs collection) -->
                                <ItemsControl ItemsSource="{Binding Tabs}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="4,6" Margin="2,2,0,0" Cursor="Hand"
                                                    CornerRadius="4,4,0,0"
                                                    MouseLeftButtonDown="SessionTab_Click">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#2a2d2e"/>
                                                            </Trigger>
                                                            <DataTrigger Value="True">
                                                                <DataTrigger.Binding>
                                                                    <MultiBinding Converter="{StaticResource EqualityConverter}">
                                                                        <Binding />
                                                                        <Binding Path="DataContext.SelectedTab"
                                                                                 RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                                    </MultiBinding>
                                                                </DataTrigger.Binding>
                                                                <Setter Property="Background" Value="#1e1e1e"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel x:Name="TabHeader" Orientation="Horizontal" Margin="2,0">
                                                    <StackPanel.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="Close" Click="TabClose_Click">
                                                                <MenuItem.Icon>
                                                                    <iconPacks:PackIconMaterial Kind="Close" Width="14" Height="14"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Header="Close Others" Click="TabCloseOthers_Click"/>
                                                            <MenuItem Header="Close All" Click="TabCloseAll_Click"/>
                                                            <MenuItem Header="Close Tabs to the Right" Click="TabCloseToRight_Click"/>
                                                            <Separator/>
                                                            <MenuItem Header="Duplicate" Click="TabDuplicate_Click">
                                                                <MenuItem.Icon>
                                                                    <iconPacks:PackIconMaterial Kind="ContentCopy" Width="14" Height="14"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <Separator/>
                                                            <MenuItem Header="Reconnect" Click="TabReconnect_Click">
                                                                <MenuItem.Icon>
                                                                    <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                        </ContextMenu>
                                                    </StackPanel.ContextMenu>
                                                    <!-- Status dot -->
                                                    <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                                             Fill="{Binding IsConnected, Converter={StaticResource StatusToColor}}"/>
                                                    <TextBlock Text="{Binding Title}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <!-- Close button: visible on hover -->
                                                    <Button x:Name="CloseBtn"
                                                            Click="TabCloseButton_Click"
                                                            ToolTip="Close" Padding="2"
                                                            Width="18" Height="18">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button.Chromeless}">
                                                                <Setter Property="Opacity" Value="0"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Value="True">
                                                                        <DataTrigger.Binding>
                                                                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                                                                <Binding Path="DataContext"
                                                                                         RelativeSource="{RelativeSource Self}"/>
                                                                                <Binding Path="DataContext.SelectedTab"
                                                                                         RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                                            </MultiBinding>
                                                                        </DataTrigger.Binding>
                                                                        <Setter Property="Opacity" Value="0.7"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsMouseOver, ElementName=TabHeader}" Value="True">
                                                                        <Setter Property="Opacity" Value="0.7"/>
                                                                    </DataTrigger>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Opacity" Value="1"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <iconPacks:PackIconMaterial Kind="Close" Width="10" Height="10"/>
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- Content area -->
                <Grid Grid.Row="1">
                    <!-- Home view (visible when IsHomeSelected is true) -->
                    <Border Background="#1e1e1e"
                            Visibility="{Binding IsHomeSelected, Converter={StaticResource BoolToVis}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="Console" Width="64" Height="64"
                                                        Foreground="#333" HorizontalAlignment="Center"
                                                        Margin="0,0,0,16"/>
                            <TextBlock Text="WinSTerm" FontSize="28" FontWeight="Light"
                                       Foreground="#555" HorizontalAlignment="Center"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Enter a host above or double-click a session to connect"
                                       FontSize="13" Foreground="#444" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Session tab content (visible when a session tab is selected) -->
                    <ContentControl Content="{Binding SelectedTab}"
                                    Visibility="{Binding IsHomeSelected, Converter={StaticResource InverseBoolToVis}}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Terminal Control -->
                                    <views:TerminalControl Grid.Row="0" />

                                    <!-- SFTP Toggle & Splitter -->
                                    <Border Grid.Row="1"
                                            Background="{StaticResource ToolbarBackground}"
                                            BorderBrush="{StaticResource SidebarBorder}" BorderThickness="0,1,0,0"
                                            Padding="4,2">
                                        <DockPanel>
                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                                <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                                         Fill="{Binding IsConnected, Converter={StaticResource StatusToColor}}"/>
                                                <TextBlock Text="{Binding StatusText}" FontSize="11" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ToggleButton x:Name="SftpToggle"
                                                          DockPanel.Dock="Right"
                                                          HorizontalAlignment="Right"
                                                          Style="{StaticResource MahApps.Styles.ToggleButton.Flat}"
                                                          IsChecked="False"
                                                          ToolTip="Toggle SFTP Browser"
                                                          Padding="6,2">
                                                <StackPanel Orientation="Horizontal">
                                                    <iconPacks:PackIconMaterial Kind="FolderNetwork" Width="14" Height="14" Margin="0,0,4,0"/>
                                                    <TextBlock Text="SFTP" FontSize="11"/>
                                                </StackPanel>
                                            </ToggleButton>
                                        </DockPanel>
                                    </Border>

                                    <!-- SFTP Browser (collapsible) -->
                                    <views:SftpBrowserControl Grid.Row="2"
                                        DataContext="{Binding SftpBrowserViewModel}"
                                        Height="250"
                                        Visibility="{Binding IsChecked, ElementName=SftpToggle, Converter={StaticResource BoolToVis}}"/>

                                </Grid>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                </Grid>
            </Grid>
        </Grid>
    </DockPanel>
</mah:MetroWindow>
