<mah:MetroWindow x:Class="WinSTerm.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:vm="clr-namespace:WinSTerm.ViewModels"
        xmlns:converters="clr-namespace:WinSTerm.Converters"
        xmlns:views="clr-namespace:WinSTerm.Views"
        mc:Ignorable="d"
        Title="WinSTerm - SSH Terminal"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen"
        TitleCharacterCasing="Normal"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        BorderThickness="1">

    <mah:MetroWindow.Resources>
        <converters:ConnectionStatusToColorConverter x:Key="StatusToColor"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
    </mah:MetroWindow.Resources>

    <DockPanel LastChildFill="True">

        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top" Background="{StaticResource ToolbarBackground}">
            <MenuItem Header="_File">
                <MenuItem Header="_New Connection" Click="NewConnection_Click">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="New _Folder" Command="{Binding AddFolderCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="FolderPlus" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Sessions">
                <MenuItem Header="_Quick Connect" Command="{Binding QuickConnectCommand}"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About WinSTerm"/>
            </MenuItem>
        </Menu>

        <!-- Quick Connect Toolbar -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource ToolbarBackground}"
                BorderBrush="{StaticResource SidebarBorder}" BorderThickness="0,0,0,1"
                Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <iconPacks:PackIconMaterial Kind="ServerNetwork" VerticalAlignment="Center"
                                           Margin="0,0,6,0" Width="16" Height="16"
                                           Foreground="{StaticResource AccentBlueBrush}"/>

                <TextBlock Text="Host:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Width="180"
                         Text="{Binding QuickHost, UpdateSourceTrigger=PropertyChanged}"
                         mah:TextBoxHelper.Watermark="hostname or IP"
                         Margin="0,0,8,0"/>

                <TextBlock Text="User:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Width="120"
                         Text="{Binding QuickUsername, UpdateSourceTrigger=PropertyChanged}"
                         mah:TextBoxHelper.Watermark="username"
                         Margin="0,0,8,0"/>

                <TextBlock Text="Port:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <mah:NumericUpDown Width="80" Value="{Binding QuickPort}"
                                   Minimum="1" Maximum="65535"
                                   Margin="0,0,8,0" NumericInputMode="Numbers"/>

                <Button Click="QuickConnect_Click"
                        Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                        Padding="12,4">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Connection" Width="14" Height="14" Margin="0,0,4,0"/>
                        <TextBlock Text="Connect"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom" Background="{StaticResource StatusBarBackground}">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Information" Width="12" Height="12"
                                               Margin="0,0,4,0"
                                               Foreground="{StaticResource StatusBarForeground}"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource StatusBarForeground}"/>
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Monitor" Width="12" Height="12"
                                               Margin="0,0,4,0"
                                               Foreground="{StaticResource StatusBarForeground}"/>
                    <TextBlock Foreground="{StaticResource StatusBarForeground}">
                        <Run Text="{Binding ConnectionCount, Mode=OneWay}"/>
                        <Run Text=" session(s)"/>
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- Main Content: Sidebar + Tabs -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="150" MaxWidth="500"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Sidebar: Session Tree -->
            <Border Grid.Column="0"
                    Background="{StaticResource SidebarBackground}"
                    BorderBrush="{StaticResource SidebarBorder}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Sidebar Header -->
                    <Border DockPanel.Dock="Top" Padding="8,6"
                            Background="{StaticResource ToolbarBackground}"
                            BorderBrush="{StaticResource SidebarBorder}" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <TextBlock Text="Sessions" FontWeight="SemiBold" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Command="{Binding AddFolderCommand}" ToolTip="New Folder"
                                        Style="{StaticResource MahApps.Styles.Button.Chromeless}"
                                        Padding="4" Margin="2,0">
                                    <iconPacks:PackIconMaterial Kind="FolderPlus" Width="14" Height="14"/>
                                </Button>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- TreeView -->
                    <TreeView x:Name="SessionTreeView"
                              ItemsSource="{Binding SessionTree}"
                              Background="Transparent" BorderThickness="0"
                              Padding="4"
                              MouseDoubleClick="SessionTree_MouseDoubleClick">
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type vm:SessionTreeItem}"
                                                       ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <StackPanel.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Connect" Click="ConnectMenuItem_Click">
                                                <MenuItem.Icon>
                                                    <iconPacks:PackIconMaterial Kind="Connection" Width="14" Height="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Edit" Click="EditMenuItem_Click">
                                                <MenuItem.Icon>
                                                    <iconPacks:PackIconMaterial Kind="Pencil" Width="14" Height="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator/>
                                            <MenuItem Header="Delete" Click="DeleteMenuItem_Click">
                                                <MenuItem.Icon>
                                                    <iconPacks:PackIconMaterial Kind="Delete" Width="14" Height="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </StackPanel.ContextMenu>
                                    <!-- Folder icon -->
                                    <iconPacks:PackIconMaterial Kind="Folder" Width="14" Height="14"
                                                                Foreground="#dca756"
                                                                Visibility="{Binding IsFolder, Converter={StaticResource BoolToVis}}"
                                                                Margin="0,0,6,0"/>
                                    <!-- Connection icon -->
                                    <iconPacks:PackIconMaterial Kind="Console" Width="14" Height="14"
                                                                Foreground="{StaticResource AccentBlueBrush}"
                                                                Visibility="{Binding IsFolder, Converter={StaticResource InverseBoolToVis}}"
                                                                Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.Resources>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </DockPanel>
            </Border>

            <!-- Grid Splitter -->
            <GridSplitter Grid.Column="1" Width="3"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="{StaticResource SidebarBorder}"/>

            <!-- Center: Tab Control -->
            <Grid Grid.Column="2">
                <!-- Welcome screen when no tabs are open -->
                <Border Background="#1e1e1e"
                        Visibility="{Binding SelectedTab, Converter={StaticResource InverseBoolToVis}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="Console" Width="64" Height="64"
                                                    Foreground="#333" HorizontalAlignment="Center"
                                                    Margin="0,0,0,16"/>
                        <TextBlock Text="WinSTerm" FontSize="28" FontWeight="Light"
                                   Foreground="#555" HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Enter a host above or double-click a session to connect"
                                   FontSize="13" Foreground="#444" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Tab Control -->
                <TabControl ItemsSource="{Binding Tabs}"
                            SelectedItem="{Binding SelectedTab}"
                            Background="Transparent"
                            BorderThickness="0">
                    <!-- Tab Header Template -->
                    <TabControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2,0">
                                <!-- Status dot -->
                                <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                         Fill="{Binding IsConnected, Converter={StaticResource StatusToColor}}"/>
                                <TextBlock Text="{Binding Title}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <!-- Close button -->
                                <Button Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource MahApps.Styles.Button.Chromeless}"
                                        ToolTip="Close" Padding="2"
                                        Width="18" Height="18">
                                    <iconPacks:PackIconMaterial Kind="Close" Width="10" Height="10"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </TabControl.ItemTemplate>

                    <!-- Tab Content Template -->
                    <TabControl.ContentTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Terminal Control -->
                                <views:TerminalControl x:Name="TerminalArea" Grid.Row="0" />

                                <!-- SFTP Toggle & Splitter -->
                                <Border Grid.Row="1"
                                        Background="{StaticResource ToolbarBackground}"
                                        BorderBrush="{StaticResource SidebarBorder}" BorderThickness="0,1,0,0"
                                        Padding="4,2">
                                    <DockPanel>
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                            <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                                     Fill="{Binding IsConnected, Converter={StaticResource StatusToColor}}"/>
                                            <TextBlock Text="{Binding StatusText}" FontSize="11" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ToggleButton x:Name="SftpToggle"
                                                      DockPanel.Dock="Right"
                                                      HorizontalAlignment="Right"
                                                      Style="{StaticResource MahApps.Styles.ToggleButton.Flat}"
                                                      IsChecked="False"
                                                      ToolTip="Toggle SFTP Browser"
                                                      Padding="6,2">
                                            <StackPanel Orientation="Horizontal">
                                                <iconPacks:PackIconMaterial Kind="FolderNetwork" Width="14" Height="14" Margin="0,0,4,0"/>
                                                <TextBlock Text="SFTP" FontSize="11"/>
                                            </StackPanel>
                                        </ToggleButton>
                                    </DockPanel>
                                </Border>

                                <!-- SFTP Browser (collapsible) -->
                                <views:SftpBrowserControl Grid.Row="2"
                                    Height="250"
                                    Visibility="{Binding IsChecked, ElementName=SftpToggle, Converter={StaticResource BoolToVis}}"/>

                            </Grid>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>
            </Grid>
        </Grid>
    </DockPanel>
</mah:MetroWindow>
