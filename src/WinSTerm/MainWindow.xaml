<mah:MetroWindow x:Class="WinSTerm.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:vm="clr-namespace:WinSTerm.ViewModels"
        xmlns:converters="clr-namespace:WinSTerm.Converters"
        xmlns:views="clr-namespace:WinSTerm.Views"
        mc:Ignorable="d"
        Title="WinSTerm - SSH Terminal"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen"
        TitleCharacterCasing="Normal"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        BorderThickness="1">

    <mah:MetroWindow.Resources>
        <converters:ConnectionStatusToColorConverter x:Key="StatusToColor"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        <converters:NullToVisibilityConverter x:Key="NullToVis"/>
        <converters:InverseNullToVisibilityConverter x:Key="NullToCollapsed"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
        <converters:FileSizeConverter x:Key="FileSizeConverter"/>

        <!-- Sidebar tab toggle style (RadioButton as flat tab) -->
        <Style x:Key="SidebarTabStyle" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border"
                                Background="Transparent"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Padding="8,6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="BorderBrush"
                                        Value="{StaticResource AccentBlueBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter Property="Foreground" Value="#999"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3e3e42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </mah:MetroWindow.Resources>

    <DockPanel LastChildFill="True">

        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top" Background="{StaticResource ToolbarBackground}">
            <MenuItem Header="_File">
                <MenuItem Header="_New Connection" Click="NewConnection_Click">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="New _Folder" Command="{Binding AddFolderCommand}">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="FolderPlus" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Settings" Click="Settings_Click" InputGestureText="Ctrl+,">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="Cog" Width="14" Height="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Sessions">
                <MenuItem Header="_Quick Connect" Command="{Binding QuickConnectCommand}"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About WinSTerm"/>
            </MenuItem>
        </Menu>

        <!-- Quick Connect Toolbar -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource ToolbarBackground}"
                BorderBrush="{StaticResource SidebarBorder}" BorderThickness="0,0,0,1"
                Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <iconPacks:PackIconMaterial Kind="ServerNetwork" VerticalAlignment="Center"
                                           Margin="0,0,6,0" Width="16" Height="16"
                                           Foreground="{StaticResource AccentBlueBrush}"/>

                <TextBlock Text="Host:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Width="180"
                         Text="{Binding QuickHost, UpdateSourceTrigger=PropertyChanged}"
                         mah:TextBoxHelper.Watermark="hostname or IP"
                         Margin="0,0,8,0"/>

                <TextBlock Text="User:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Width="120"
                         Text="{Binding QuickUsername, UpdateSourceTrigger=PropertyChanged}"
                         mah:TextBoxHelper.Watermark="username"
                         Margin="0,0,8,0"/>

                <TextBlock Text="Port:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <mah:NumericUpDown Width="80" Value="{Binding QuickPort}"
                                   Minimum="1" Maximum="65535"
                                   Margin="0,0,8,0" NumericInputMode="Numbers"/>

                <Button Click="QuickConnect_Click"
                        Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                        Padding="12,4">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Connection" Width="14" Height="14" Margin="0,0,4,0"/>
                        <TextBlock Text="Connect"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom" Background="{StaticResource StatusBarBackground}">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Information" Width="12" Height="12"
                                               Margin="0,0,4,0"
                                               Foreground="{StaticResource StatusBarForeground}"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource StatusBarForeground}"/>
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Monitor" Width="12" Height="12"
                                               Margin="0,0,4,0"
                                               Foreground="{StaticResource StatusBarForeground}"/>
                    <TextBlock Foreground="{StaticResource StatusBarForeground}">
                        <Run Text="{Binding ConnectionCount, Mode=OneWay}"/>
                        <Run Text=" session(s)"/>
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- Main Content: Sidebar + Tabs -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="150" MaxWidth="500"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Sidebar: Session Tree -->
            <Border Grid.Column="0"
                    Background="{StaticResource SidebarBackground}"
                    BorderBrush="{StaticResource SidebarBorder}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Sidebar Header -->
                    <Border DockPanel.Dock="Top" Padding="8,6"
                            Background="{StaticResource ToolbarBackground}"
                            BorderBrush="{StaticResource SidebarBorder}" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <TextBlock Text="Sessions" FontWeight="SemiBold" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Command="{Binding AddFolderCommand}" ToolTip="New Folder"
                                        Style="{StaticResource MahApps.Styles.Button.Chromeless}"
                                        Padding="4" Margin="2,0">
                                    <iconPacks:PackIconMaterial Kind="FolderPlus" Width="14" Height="14"/>
                                </Button>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- TreeView -->
                    <TreeView x:Name="SessionTreeView"
                              ItemsSource="{Binding SessionTree}"
                              Background="Transparent" BorderThickness="0"
                              Padding="4"
                              MouseDoubleClick="SessionTree_MouseDoubleClick">
                        <TreeView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="New Connection" Click="NewConnectionFromTree_Click">
                                    <MenuItem.Icon>
                                        <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="New Folder" Click="NewFolderFromTree_Click">
                                    <MenuItem.Icon>
                                        <iconPacks:PackIconMaterial Kind="FolderPlus" Width="14" Height="14"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </TreeView.ContextMenu>
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type vm:SessionTreeItem}"
                                                       ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <StackPanel.ContextMenu>
                                        <ContextMenu>
                                            <!-- Connection-only: Connect -->
                                            <MenuItem Header="Connect" Click="ConnectMenuItem_Click"
                                                      Visibility="{Binding IsFolder, Converter={StaticResource InverseBoolToVis}}">
                                                <MenuItem.Icon>
                                                    <iconPacks:PackIconMaterial Kind="Connection" Width="14" Height="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <!-- Folder-only: New Connection Here -->
                                            <MenuItem Header="New Connection Here" Click="NewConnectionInFolder_Click"
                                                      Visibility="{Binding IsFolder, Converter={StaticResource BoolToVis}}">
                                                <MenuItem.Icon>
                                                    <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <!-- Folder-only: New Subfolder -->
                                            <MenuItem Header="New Subfolder" Click="NewSubfolderInFolder_Click"
                                                      Visibility="{Binding IsFolder, Converter={StaticResource BoolToVis}}">
                                                <MenuItem.Icon>
                                                    <iconPacks:PackIconMaterial Kind="FolderPlus" Width="14" Height="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator/>
                                            <!-- Folder-only: Rename -->
                                            <MenuItem Header="Rename" Click="RenameItem_Click"
                                                      Visibility="{Binding IsFolder, Converter={StaticResource BoolToVis}}">
                                                <MenuItem.Icon>
                                                    <iconPacks:PackIconMaterial Kind="Pencil" Width="14" Height="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <!-- Connection-only: Edit -->
                                            <MenuItem Header="Edit" Click="EditMenuItem_Click"
                                                      Visibility="{Binding IsFolder, Converter={StaticResource InverseBoolToVis}}">
                                                <MenuItem.Icon>
                                                    <iconPacks:PackIconMaterial Kind="Pencil" Width="14" Height="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator/>
                                            <!-- Both: Delete -->
                                            <MenuItem Header="Delete" Click="DeleteMenuItem_Click">
                                                <MenuItem.Icon>
                                                    <iconPacks:PackIconMaterial Kind="Delete" Width="14" Height="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </StackPanel.ContextMenu>
                                    <!-- Folder icon -->
                                    <iconPacks:PackIconMaterial Kind="Folder" Width="14" Height="14"
                                                                Foreground="#dca756"
                                                                Visibility="{Binding IsFolder, Converter={StaticResource BoolToVis}}"
                                                                Margin="0,0,6,0"/>
                                    <!-- Connection icon -->
                                    <iconPacks:PackIconMaterial Kind="Console" Width="14" Height="14"
                                                                Foreground="{StaticResource AccentBlueBrush}"
                                                                Visibility="{Binding IsFolder, Converter={StaticResource InverseBoolToVis}}"
                                                                Margin="0,0,6,0"/>
                                    <!-- Normal mode: display name -->
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                               Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVis}}"/>
                                    <!-- Edit mode: editable name -->
                                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                                             MinWidth="100" VerticalAlignment="Center"
                                             LostFocus="TreeItemTextBox_LostFocus"
                                             PreviewKeyDown="TreeItemTextBox_KeyDown"
                                             Loaded="TreeItemTextBox_Loaded"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.Resources>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </DockPanel>
            </Border>

            <!-- Grid Splitter -->
            <GridSplitter Grid.Column="1" Width="3"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="{StaticResource SidebarBorder}"/>

            <!-- Center: Tab Control -->
            <Grid Grid.Column="2">
                <!-- Welcome screen when no tabs are open -->
                <Border Background="#1e1e1e"
                        Visibility="{Binding SelectedTab, Converter={StaticResource NullToVis}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="Console" Width="64" Height="64"
                                                    Foreground="#333" HorizontalAlignment="Center"
                                                    Margin="0,0,0,16"/>
                        <TextBlock Text="WinSTerm" FontSize="28" FontWeight="Light"
                                   Foreground="#555" HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Enter a host above or double-click a session to connect"
                                   FontSize="13" Foreground="#444" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Tab Control -->
                <TabControl ItemsSource="{Binding Tabs}"
                            SelectedItem="{Binding SelectedTab}"
                            Background="Transparent"
                            BorderThickness="0"
                            Visibility="{Binding SelectedTab, Converter={StaticResource NullToCollapsed}}">

                    <!-- Custom TabControl template with "+" button -->
                    <TabControl.Template>
                        <ControlTemplate TargetType="TabControl">
                            <Grid ClipToBounds="True" SnapsToDevicePixels="True"
                                  KeyboardNavigation.TabNavigation="Local">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <!-- Tab header strip -->
                                <Border Grid.Row="0"
                                        Background="{StaticResource ToolbarBackground}"
                                        BorderBrush="{StaticResource SidebarBorder}"
                                        BorderThickness="0,0,0,1">
                                    <DockPanel>
                                        <!-- New tab button -->
                                        <Button DockPanel.Dock="Right"
                                                Click="NewTabButton_Click"
                                                ToolTip="New Connection"
                                                Style="{StaticResource MahApps.Styles.Button.Chromeless}"
                                                Padding="6,4" Margin="2"
                                                VerticalAlignment="Center">
                                            <iconPacks:PackIconMaterial Kind="Plus" Width="12" Height="12"
                                                                        Foreground="{StaticResource AccentBlueBrush}"/>
                                        </Button>
                                        <!-- Tab headers -->
                                        <TabPanel x:Name="HeaderPanel"
                                                  IsItemsHost="True"
                                                  Panel.ZIndex="1"
                                                  KeyboardNavigation.TabIndex="1"
                                                  Margin="0,2,0,0"/>
                                    </DockPanel>
                                </Border>
                                <!-- Tab content -->
                                <Border Grid.Row="1" Background="Transparent" BorderThickness="0">
                                    <ContentPresenter x:Name="PART_SelectedContentHost"
                                                      ContentSource="SelectedContent"
                                                      Margin="0"/>
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </TabControl.Template>

                    <!-- Tab item container style with hover effect -->
                    <TabControl.ItemContainerStyle>
                        <Style TargetType="TabItem" BasedOn="{StaticResource {x:Type TabItem}}">
                            <Setter Property="Padding" Value="4,4"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2a2d2e"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#1e1e1e"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TabControl.ItemContainerStyle>

                    <!-- Tab Header Template -->
                    <TabControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel x:Name="TabHeader" Orientation="Horizontal" Margin="2,0">
                                <StackPanel.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Close" Click="TabClose_Click">
                                            <MenuItem.Icon>
                                                <iconPacks:PackIconMaterial Kind="Close" Width="14" Height="14"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Close Others" Click="TabCloseOthers_Click"/>
                                        <MenuItem Header="Close All" Click="TabCloseAll_Click"/>
                                        <MenuItem Header="Close Tabs to the Right" Click="TabCloseToRight_Click"/>
                                        <Separator/>
                                        <MenuItem Header="Duplicate" Click="TabDuplicate_Click">
                                            <MenuItem.Icon>
                                                <iconPacks:PackIconMaterial Kind="ContentCopy" Width="14" Height="14"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <Separator/>
                                        <MenuItem Header="Reconnect" Click="TabReconnect_Click">
                                            <MenuItem.Icon>
                                                <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </StackPanel.ContextMenu>
                                <!-- Status dot -->
                                <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                         Fill="{Binding IsConnected, Converter={StaticResource StatusToColor}}"/>
                                <TextBlock Text="{Binding Title}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <!-- Close button: visible on hover or when selected -->
                                <Button x:Name="CloseBtn"
                                        Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Close" Padding="2"
                                        Width="18" Height="18">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button.Chromeless}">
                                            <Setter Property="Opacity" Value="0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TabItem}}" Value="True">
                                                    <Setter Property="Opacity" Value="0.7"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsMouseOver, ElementName=TabHeader}" Value="True">
                                                    <Setter Property="Opacity" Value="0.7"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="1"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <iconPacks:PackIconMaterial Kind="Close" Width="10" Height="10"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </TabControl.ItemTemplate>

                    <!-- Tab Content Template -->
                    <TabControl.ContentTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Terminal Control -->
                                <views:TerminalControl Grid.Row="0" />

                                <!-- SFTP Toggle & Splitter -->
                                <Border Grid.Row="1"
                                        Background="{StaticResource ToolbarBackground}"
                                        BorderBrush="{StaticResource SidebarBorder}" BorderThickness="0,1,0,0"
                                        Padding="4,2">
                                    <DockPanel>
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                            <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                                     Fill="{Binding IsConnected, Converter={StaticResource StatusToColor}}"/>
                                            <TextBlock Text="{Binding StatusText}" FontSize="11" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ToggleButton x:Name="SftpToggle"
                                                      DockPanel.Dock="Right"
                                                      HorizontalAlignment="Right"
                                                      Style="{StaticResource MahApps.Styles.ToggleButton.Flat}"
                                                      IsChecked="False"
                                                      ToolTip="Toggle SFTP Browser"
                                                      Padding="6,2">
                                            <StackPanel Orientation="Horizontal">
                                                <iconPacks:PackIconMaterial Kind="FolderNetwork" Width="14" Height="14" Margin="0,0,4,0"/>
                                                <TextBlock Text="SFTP" FontSize="11"/>
                                            </StackPanel>
                                        </ToggleButton>
                                    </DockPanel>
                                </Border>

                                <!-- SFTP Browser (collapsible) -->
                                <views:SftpBrowserControl Grid.Row="2"
                                    DataContext="{Binding SftpBrowserViewModel}"
                                    Height="250"
                                    Visibility="{Binding IsChecked, ElementName=SftpToggle, Converter={StaticResource BoolToVis}}"/>

                            </Grid>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>
            </Grid>
        </Grid>
    </DockPanel>
</mah:MetroWindow>
