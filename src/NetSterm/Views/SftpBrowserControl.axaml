<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:vm="clr-namespace:NetSterm.ViewModels"
             xmlns:converters="clr-namespace:NetSterm.Converters"
             xmlns:models="clr-namespace:NetSterm.Models"
             x:Class="NetSterm.Views.SftpBrowserControl"
             x:DataType="vm:SftpBrowserViewModel">

    <UserControl.Resources>
        <converters:FileSizeConverter x:Key="FileSizeConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Dual-pane file browser -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- LOCAL PANE (Left) -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Local path bar -->
                <Grid Grid.Row="0" Margin="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Margin="0,0,4,0"
                            Command="{Binding NavigateLocalUpCommand}"
                            Width="32" Height="32"
                            ToolTip.Tip="Parent Directory"
                            Padding="0">
                        <mi:MaterialIcon Kind="ArrowUp" Width="14" Height="14"/>
                    </Button>

                    <TextBox Grid.Column="1" Margin="0,0,4,0"
                             Text="{Binding LocalPath}"
                             Watermark="Local path"
                             VerticalContentAlignment="Center"
                             x:Name="LocalPathBox"
                             KeyDown="LocalPathBox_KeyDown"/>

                    <Button Grid.Column="2"
                            Command="{Binding RefreshLocalCommand}"
                            Width="32" Height="32"
                            ToolTip.Tip="Refresh"
                            Padding="0">
                        <mi:MaterialIcon Kind="Refresh" Width="14" Height="14"/>
                    </Button>
                </Grid>

                <!-- Local file list -->
                <DataGrid Grid.Row="1" Margin="4,0,4,4"
                          x:Name="LocalFilesGrid"
                          x:CompileBindings="False"
                          ItemsSource="{Binding LocalFiles}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Extended"
                          CanUserReorderColumns="False"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column"
                          DoubleTapped="LocalFilesGrid_DoubleTapped"
                          SelectionChanged="LocalFilesGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="30" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Panel>
                                        <mi:MaterialIcon Kind="Folder" Width="14" Height="14"
                                            Foreground="#DCBB67"
                                            VerticalAlignment="Center" HorizontalAlignment="Center"
                                            IsVisible="{Binding IsDirectory}"/>
                                        <mi:MaterialIcon Kind="FileOutline" Width="14" Height="14"
                                            VerticalAlignment="Center" HorizontalAlignment="Center"
                                            IsVisible="{Binding !IsDirectory}"/>
                                    </Panel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTemplateColumn Header="Size" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SizeDisplay}"
                                               TextAlignment="Right"
                                               VerticalAlignment="Center"
                                               Margin="4,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Modified"
                                            Binding="{Binding LastModified, StringFormat={}{0:yyyy-MM-dd HH:mm}}"
                                            Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Grid Splitter -->
            <GridSplitter Grid.Column="1" Width="4" ResizeDirection="Columns"/>

            <!-- REMOTE PANE (Right) -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Remote path bar -->
                <Grid Grid.Row="0" Margin="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Margin="0,0,4,0"
                            Command="{Binding NavigateRemoteUpCommand}"
                            Width="32" Height="32"
                            ToolTip.Tip="Parent Directory"
                            Padding="0">
                        <mi:MaterialIcon Kind="ArrowUp" Width="14" Height="14"/>
                    </Button>

                    <TextBox Grid.Column="1" Margin="0,0,4,0"
                             Text="{Binding RemotePath}"
                             Watermark="Remote path"
                             VerticalContentAlignment="Center"
                             x:Name="RemotePathBox"
                             KeyDown="RemotePathBox_KeyDown"/>

                    <Button Grid.Column="2"
                            Command="{Binding RefreshRemoteCommand}"
                            Width="32" Height="32"
                            ToolTip.Tip="Refresh"
                            Padding="0">
                        <mi:MaterialIcon Kind="Refresh" Width="14" Height="14"/>
                    </Button>
                </Grid>

                <!-- Remote file list -->
                <DataGrid Grid.Row="1" Margin="4,0,4,4"
                          x:Name="RemoteFilesGrid"
                          x:CompileBindings="False"
                          ItemsSource="{Binding RemoteFiles}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Extended"
                          CanUserReorderColumns="False"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column"
                          DoubleTapped="RemoteFilesGrid_DoubleTapped"
                          SelectionChanged="RemoteFilesGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="30" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Panel>
                                        <mi:MaterialIcon Kind="Folder" Width="14" Height="14"
                                            Foreground="#DCBB67"
                                            VerticalAlignment="Center" HorizontalAlignment="Center"
                                            IsVisible="{Binding IsDirectory}"/>
                                        <mi:MaterialIcon Kind="FileOutline" Width="14" Height="14"
                                            VerticalAlignment="Center" HorizontalAlignment="Center"
                                            IsVisible="{Binding !IsDirectory}"/>
                                    </Panel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTemplateColumn Header="Size" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SizeDisplay}"
                                               TextAlignment="Right"
                                               VerticalAlignment="Center"
                                               Margin="4,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Modified"
                                            Binding="{Binding LastModified, StringFormat={}{0:yyyy-MM-dd HH:mm}}"
                                            Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- Bottom toolbar: transfers and actions -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Action buttons -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,6">
                <Button Command="{Binding UploadCommand}"
                        Height="30" Padding="12,0" Margin="0,0,8,0"
                        ToolTip.Tip="Upload selected local files to remote">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Upload" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <mi:MaterialIcon Kind="ArrowRight" Width="12" Height="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding DownloadCommand}"
                        Height="30" Padding="12,0" Margin="0,0,8,0"
                        ToolTip.Tip="Download selected remote files to local">
                    <StackPanel Orientation="Horizontal">
                        <mi:MaterialIcon Kind="ArrowLeft" Width="12" Height="12" VerticalAlignment="Center"/>
                        <TextBlock Text="Download" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                </Button>

                <Button Height="30" Padding="12,0" Margin="0,0,8,0"
                        ToolTip.Tip="Create new remote folder"
                        x:Name="CreateFolderButton"
                        Click="CreateFolderButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <mi:MaterialIcon Kind="FolderPlus" Width="14" Height="14" VerticalAlignment="Center"/>
                        <TextBlock Text="New Folder" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding ClearCompletedTransfersCommand}"
                        Height="30" Padding="12,0" Margin="0,0,8,0"
                        IsEnabled="{Binding HasCompletedTransfers}"
                        ToolTip.Tip="Clear completed and failed transfers">
                    <StackPanel Orientation="Horizontal">
                        <mi:MaterialIcon Kind="CloseCircleOutline" Width="14" Height="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Clear" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                </Button>

                <!-- Busy indicator -->
                <ProgressBar IsIndeterminate="True"
                             IsVisible="{Binding IsBusy}"
                             Width="80" Height="4"
                             Margin="8,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Active transfer progress -->
            <ItemsControl Grid.Row="1" ItemsSource="{Binding Transfers}" Margin="8,0,8,6">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:TransferItem">
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0">
                                <Panel Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center">
                                    <mi:MaterialIcon Kind="Upload" Width="12" Height="12"
                                                     IsVisible="{Binding IsUpload}"/>
                                    <mi:MaterialIcon Kind="Download" Width="12" Height="12"
                                                     IsVisible="{Binding IsDownload}"/>
                                </Panel>
                                <TextBlock Text="{Binding FileName}" VerticalAlignment="Center"
                                           MaxWidth="200" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <ProgressBar Grid.Column="1" Value="{Binding ProgressPercent}"
                                         Minimum="0" Maximum="100" Height="14"
                                         VerticalAlignment="Center" Margin="4,0"/>

                            <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                       Text="{Binding ProgressPercent, StringFormat={}{0:F0}%}"
                                       TextAlignment="Right"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</UserControl>
